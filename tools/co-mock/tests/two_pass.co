// RUN: co-mock %s 2>&1 | FileCheck %s

// Two-pass pattern: count then compact.

__co__ void two_pass_test() {
  s32[8] data;
  s32[8] result;

  parallel p by 8
    data.at(p) = (p + 1) * 3;

  // Count elements > 10
  mutable int count = 0;
  foreach i in 8 {
    if (data.at(i) > 10)
      count = count + 1;
  }
  println("count =", count);

  // Compact elements > 10
  mutable int write = 0;
  foreach i in 8 {
    if (data.at(i) > 10) {
      result.at(write) = data.at(i);
      write = write + 1;
    }
  }

  println(result.at(0));
  println(result.at(1));
  println(result.at(4));
}

// CHECK: count = 5
// CHECK: 12
// CHECK: 15
// CHECK: 24
