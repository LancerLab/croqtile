// RUN: co-mock %s 2>&1 | FileCheck %s

// Test mutable variable declarations and sequential accumulation.

__co__ void mutable_test() {
  s32[4] data;

  parallel p by 4
    data.at(p) = (p + 1) * 3;

  mutable int total = 0;
  foreach i in 4
    total = total + data.at(i);

  println("total =", total);

  mutable int maxVal = data.at(0);
  foreach i in 3 {
    if (data.at(i + 1) > maxVal)
      maxVal = data.at(i + 1);
  }

  println("max =", maxVal);
}

// CHECK: total = 30
// CHECK: max = 12
