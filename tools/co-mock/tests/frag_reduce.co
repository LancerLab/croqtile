// RUN: co-mock %s 2>&1 | FileCheck %s
// Test reduce_sum and reduce_max on 2D arrays.

__co__ void frag_reduce_test() {
  s32[3, 4] mat;
  s32[3] rsum;
  s32[3] rmax;

  foreach i in 3
    foreach j in 4
      mat.at(i, j) = i * 4 + j + 1;

  foreach i in 3 {
    rsum.at(i) = 0;
    rmax.at(i) = 0;
  }

  reduce_sum(rsum, mat, 1);
  reduce_max(rmax, mat, 1);

  foreach i in 3 {
    println("sum[", i, "] =", rsum.at(i));
    println("max[", i, "] =", rmax.at(i));
  }
}

// row 0: [1,2,3,4]   sum=10  max=4
// row 1: [5,6,7,8]   sum=26  max=8
// row 2: [9,10,11,12] sum=42  max=12

// CHECK: sum[ 0 ] = 10
// CHECK: max[ 0 ] = 4
// CHECK: sum[ 1 ] = 26
// CHECK: max[ 1 ] = 8
// CHECK: sum[ 2 ] = 42
// CHECK: max[ 2 ] = 12
