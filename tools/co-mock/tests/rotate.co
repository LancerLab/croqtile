// RUN: co-mock %s 2>&1 | FileCheck %s

__co__ void rotate_test() {
  s32[4] a;
  s32[4] b;

  parallel p by 4 {
    a.at(p) = 10 + p;
    b.at(p) = 0;
  }

  f1 = dma.copy.async a => b;
  wait(f1);

  println(b.at(0));
  println(b.at(1));
  println(b.at(2));
  println(b.at(3));
}

// CHECK: 10
// CHECK: 11
// CHECK: 12
// CHECK: 13
