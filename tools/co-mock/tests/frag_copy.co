// RUN: co-mock %s 2>&1 | FileCheck %s
// Test copy() for array-to-array transfer.

__co__ void frag_copy_test() {
  s32[4] src;
  s32[4] dst;

  parallel p by 4
    src.at(p) = (p + 1) * 100;

  parallel p by 4
    dst.at(p) = 0;

  copy(dst, src);

  foreach i in 4
    println("dst[", i, "] =", dst.at(i));
}

// CHECK: dst[ 0 ] = 100
// CHECK: dst[ 1 ] = 200
// CHECK: dst[ 2 ] = 300
// CHECK: dst[ 3 ] = 400
