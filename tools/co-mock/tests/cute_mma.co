// RUN: co-mock -t cute %s 2>&1 | FileCheck %s
// Test MMA operations (exec, fill) under cute target.

__co__ void test_mma() {
  parallel t by 1 : thread {
    frag s32[2, 2] a;
    frag s32[2, 2] b;
    frag s32[2, 2] c;

    // a = [[1, 2], [2, 3]]
    foreach i in 2
      foreach j in 2
        a.at(i, j) = i + j + 1;

    // b = [[1, 2], [3, 4]]
    foreach i in 2
      foreach j in 2
        b.at(i, j) = i * 2 + j + 1;

    // c = 0
    foreach i in 2
      foreach j in 2
        c.at(i, j) = 0;

    // c += a * b^T  (row.col)
    mma.row.col c, a, b;

    foreach i in 2
      foreach j in 2
        println("c[", i, ",", j, "] =", c.at(i, j));

    // mma.fill on existing frag
    mma.fill c, 99;
    println("after fill:");
    foreach i in 2
      foreach j in 2
        println("c[", i, ",", j, "] =", c.at(i, j));
  }
}

// a = [[1,2],[2,3]], b = [[1,2],[3,4]]
// c = a * b^T = [[1*1+2*2, 1*3+2*4], [2*1+3*2, 2*3+3*4]]
//             = [[5, 11], [8, 18]]
// Wait: row.col means C += A * B  (not transpose)
// Actually for row.col: C[i][j] += sum_k A[i][k] * B[k][j]
// C[0][0] = 1*1 + 2*3 = 7
// C[0][1] = 1*2 + 2*4 = 10
// C[1][0] = 2*1 + 3*3 = 11
// C[1][1] = 2*2 + 3*4 = 16

// CHECK: c[ 0 , 0 ] = 7
// CHECK: c[ 0 , 1 ] = 10
// CHECK: c[ 1 , 0 ] = 11
// CHECK: c[ 1 , 1 ] = 16
// CHECK: after fill:
// CHECK: c[ 0 , 0 ] = 99
// CHECK: c[ 0 , 1 ] = 99
// CHECK: c[ 1 , 0 ] = 99
// CHECK: c[ 1 , 1 ] = 99
