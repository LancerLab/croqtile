// Mock-vs-Real comparison: matrix multiply using foreach.

__co__ void test() {
  s32[3, 2] A;
  s32[2, 3] B;
  s32[3, 3] C;

  foreach i in 3
    foreach j in 2
      A.at(i, j) = i * 2 + j + 1;

  foreach i in 2
    foreach j in 3
      B.at(i, j) = i * 3 + j + 1;

  foreach i in 3 {
    foreach j in 3 {
      mutable s32 sum = 0;
      foreach k in 2
        sum = sum + A.at(i, k) * B.at(k, j);
      C.at(i, j) = sum;
    }
  }

  // A=[[1,2],[3,4],[5,6]], B=[[1,2,3],[4,5,6]]
  println(C.at(0, 0));
  println(C.at(0, 1));
  println(C.at(0, 2));
  println(C.at(1, 0));
  println(C.at(1, 1));
  println(C.at(1, 2));
  println(C.at(2, 0));
  println(C.at(2, 1));
  println(C.at(2, 2));
}
