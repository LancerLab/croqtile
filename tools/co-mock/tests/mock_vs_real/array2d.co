// Mock-vs-Real comparison: 2D array indexing.

__co__ void test() {
  s32[3, 4] mat;

  foreach i in 3
    foreach j in 4
      mat.at(i, j) = i * 4 + j;

  println(mat.at(0, 0));
  println(mat.at(0, 3));
  println(mat.at(1, 0));
  println(mat.at(2, 3));

  // Row sum of row 1
  mutable s32 rsum = 0;
  foreach j in 4
    rsum = rsum + mat.at(1, j);
  println(rsum);
}
