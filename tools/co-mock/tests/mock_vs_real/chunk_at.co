// Mock-vs-Real comparison: .at() returns scalar value.

__co__ void test() {
  s32[4] arr;
  foreach i in 4
    arr.at(i) = (i + 1) * 100;

  s32 elem0 = arr.at(0);
  s32 elem2 = arr.at(2);
  println(elem0);
  println(elem2);

  // Verify indirect indexing
  mutable s32 idx = 1;
  println(arr.at(idx));
  idx = idx + 2;
  println(arr.at(idx));
}
