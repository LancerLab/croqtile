// Mock-vs-Real comparison: negative numbers and mixed-sign arithmetic.

__co__ void test() {
  s32 a = -5;
  s32 b = 3;
  println(a + b);
  println(a - b);
  println(a * b);
  println(a / b);
  println(a % b);

  // Negation
  s32 c = 0 - a;
  println(c);

  // Nested negative expressions
  s32 d = (a + b) * (a - b);
  println(d);

  // Negative array values
  s32[4] arr;
  foreach i in 4
    arr.at(i) = i * 2 - 3;
  println(arr.at(0));
  println(arr.at(1));
  println(arr.at(2));
  println(arr.at(3));
}
