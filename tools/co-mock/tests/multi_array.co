// RUN: co-mock %s 2>&1 | FileCheck %s

// Element-wise operations across multiple arrays.

__co__ void multi_array_test() {
  s32[4] a;
  s32[4] b;
  s32[4] c;

  parallel p by 4 {
    a.at(p) = p + 1;
    b.at(p) = (p + 1) * 10;
  }

  parallel p by 4
    c.at(p) = a.at(p) + b.at(p);

  foreach i in 4
    println("c[", i, "] =", c.at(i));
}

// CHECK: c[ 0 ] = 11
// CHECK: c[ 1 ] = 22
// CHECK: c[ 2 ] = 33
// CHECK: c[ 3 ] = 44
