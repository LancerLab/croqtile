// RUN: co-mock %s 2>&1 | FileCheck %s

// Test matrix multiply using foreach (non-MMA path).

__co__ void matmul_test() {
  s32[3, 2] A;
  s32[2, 3] B;
  s32[3, 3] C;

  foreach i in 3
    foreach j in 2
      A.at(i, j) = i * 2 + j + 1;

  foreach i in 2
    foreach j in 3
      B.at(i, j) = i * 3 + j + 1;

  foreach i in 3 {
    foreach j in 3 {
      mutable int sum = 0;
      foreach k in 2
        sum = sum + A.at(i, k) * B.at(k, j);
      C.at(i, j) = sum;
    }
  }

  // A=[[1,2],[3,4],[5,6]], B=[[1,2,3],[4,5,6]]
  // C[0,0]=1*1+2*4=9, C[0,1]=1*2+2*5=12, C[0,2]=1*3+2*6=15
  // C[1,0]=3*1+4*4=19, C[2,2]=5*3+6*6=51
  println(C.at(0, 0));
  println(C.at(0, 1));
  println(C.at(0, 2));
  println(C.at(1, 0));
  println(C.at(2, 2));
}

// CHECK: 9
// CHECK: 12
// CHECK: 15
// CHECK: 19
// CHECK: 51
