// REQUIRES: TARGET-AMDGPU
// RUN: cocc -t hip -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
//
// Integral type operations: s32, u32.

__co__ s32 [64] int_add(s32 [64] a, s32 [64] b) {
  s32[a.span] c;
  parallel p by 64
    c.at(p) = a.at(p) + b.at(p);
  return c;
}

__co__ s32 [64] int_mul(s32 [64] a, s32 [64] b) {
  s32[a.span] c;
  parallel p by 64
    c.at(p) = a.at(p) * b.at(p);
  return c;
}

int main() {
  auto a = choreo::make_spandata<choreo::s32>(64);
  auto b = choreo::make_spandata<choreo::s32>(64);
  a.fill_random(-10, 10);
  b.fill_random(-10, 10);

  auto res_add = int_add(a.view(), b.view());
  for (size_t i = 0; i < 64; ++i)
    choreo::choreo_assert(a[i] + b[i] == res_add[i], "add mismatch");

  auto res_mul = int_mul(a.view(), b.view());
  for (size_t i = 0; i < 64; ++i)
    choreo::choreo_assert(a[i] * b[i] == res_mul[i], "mul mismatch");

  std::cout << "PASS: integral_types" << std::endl;
}

// CHECK: PASS: integral_types
