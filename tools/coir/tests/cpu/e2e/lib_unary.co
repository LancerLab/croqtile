// RUN: cocc -t cc -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
//
// End-to-end: __lib_add elementwise then verify.

__co__ void test_lib_add(f32 [4] a, f32 [4] b, f32 [4] c) {
  __lib_add(c, a, b, 4);
}

int main() {
  auto a = choreo::make_spandata<choreo::f32>(4);
  auto b = choreo::make_spandata<choreo::f32>(4);
  auto c = choreo::make_spandata<choreo::f32>(4);
  for (int i = 0; i < 4; ++i) { a[i] = (float)i; b[i] = (float)(i*2); }
  test_lib_add(a.view(), b.view(), c.view());
  bool pass = true;
  for (int i = 0; i < 4; ++i)
    if (c[i] != a[i] + b[i]) pass = false;
  if (pass) std::cout << "PASS" << std::endl;
  else std::cout << "FAIL" << std::endl;
}

// CHECK: PASS
