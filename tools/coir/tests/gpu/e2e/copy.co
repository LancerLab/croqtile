// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s | bash -s -- --execute | FileCheck %s
// RUN: cocc -t gpu -gs %s | bash -s -- --execute | FileCheck --check-prefix=GPU --match-full-lines %s
//
// DMA copy round-trip: sync, async, and group-scope copies.

__co__ auto dma_copy_sync(s32 [6, 17, 64] input) {
  s32 [input.span] output;

  parallel by 1, by 1 {
    f = dma.copy input => shared;
    dma.copy f.data => output;
  }

  return output;
}

__co__ auto dma_copy_async(s32 [6, 17, 64] input) {
  s32 [input.span] output;

  parallel by 1, by 1 {
    f = dma.copy.async input => shared;
    wait f;
    dma.copy f.data => output;
  }

  return output;
}

int main() {
  {
    auto a = choreo::make_spandata<choreo::s32>(6, 17, 64);
    a.fill_random(-10, 10);

    auto res0 = dma_copy_sync(a.view());

    for (size_t i = 0; i < res0.shape()[0]; ++i)
      for (size_t j = 0; j < res0.shape()[1]; ++j)
        for (size_t k = 0; k < res0.shape()[2]; ++k)
          choreo::choreo_assert(a[i][j][k] == res0[i][j][k], "values are not equal.");

    std::cout << "Test copy_sync Passed" << std::endl;

    auto res1 = dma_copy_async(a.view());

    for (size_t i = 0; i < res1.shape()[0]; ++i)
      for (size_t j = 0; j < res1.shape()[1]; ++j)
        for (size_t k = 0; k < res1.shape()[2]; ++k)
          choreo::choreo_assert(a[i][j][k] == res1[i][j][k], "values are not equal.");

    std::cout << "Test copy_async Passed" << std::endl;
  }
}

// CHECK: Test copy_sync Passed
// CHECK: Test copy_async Passed
// GPU: Test copy_sync Passed
// GPU: Test copy_async Passed
