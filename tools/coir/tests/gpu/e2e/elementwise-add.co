// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
// RUN: cocc -t gpu -gs %s | bash -s -- --execute | FileCheck --check-prefix=GPU --match-full-lines %s
//
// End-to-end GPU test

__co__ s32 [64] ele_add(s32 [64] a, s32 [64] b) {
  s32[a.span] c;
  parallel p by 64
    c.at(p) = a.at(p) + b.at(p);
  return c;
}

int main() {
  auto a = choreo::make_spandata<choreo::s32>(64);
  auto b = choreo::make_spandata<choreo::s32>(64);
  a.fill_random(-10, 10);
  b.fill_random(-10, 10);

  auto res = ele_add(a.view(), b.view());

  for (size_t i = 0; i < 64; ++i)
    choreo::choreo_assert(a[i] + b[i] == res[i], "mismatch");

  std::cout << "PASS: ele_add" << std::endl;
}

// CHECK: PASS: ele_add
// GPU: PASS: ele_add
