// REQUIRES: TARGET-GPU
// XFAIL: *
// RUN: cocc -t cute -gs %s -arch=sm_80 -o %s.result && CHOREO_DISABLE_TIMING=1 bash %s.result --execute | FileCheck --match-full-lines %s && rm -f %s.result

__co__ auto gemm_sp_basic(f16 [16, 8] lhs, f16 [16, 16] rhs) {
  f32 [16, 16] output;
  parallel m by 1 : block {
    parallel n by 1 : group {
      mma.fill mc;
      mma.load.a ma = lhs.row;
      mma.load.b mb = rhs.col;
      mma.row.col mc, ma, mb;
      mma.store output, mc;
    }
  }
  return output;
}

int main() {
  auto a = choreo::make_spandata<choreo::f16>(16, 8);
  auto b = choreo::make_spandata<choreo::f16>(16, 16);
  a.fill_random(-1, 1);
  b.fill_random(-1, 1);
  auto c = gemm_sp_basic(a.view(), b.view());
  std::cout << "GEMM SP SM80 Test Passed" << std::endl;
}

// CHECK: GEMM SP SM80 Test Passed
