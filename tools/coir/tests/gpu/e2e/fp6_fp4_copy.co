// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -arch=sm_86 -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
//

__co__ auto dma_copy_f6(f6_e2m3 [M, 17, 32] input) {
  f6_e2m3 [input.span] output;

  parallel by 1 : group {
    f = dma.copy.async input => shared;
    wait f;
    dma.copy f.data => output;
  }

  return output;
}

__co__ auto dma_copy_f4(f4_e2m1 [M, 17, 32] input) {
  f4_e2m1 [input.span] output;

  parallel by 1 : group {
    f = dma.copy.async input => shared;
    wait f;
    dma.copy f.data => output;
  }

  return output;
}

int main() {
  auto a6 = choreo::make_spandata<choreo::f6_e2m3>(6, 17, 32);
  a6.fill_random(-2.0f, 2.0f);

  auto res6 = dma_copy_f6(a6.view());

  for (size_t i = 0; i < res6.shape()[0]; ++i)
    for (size_t j = 0; j < res6.shape()[1]; ++j)
      for (size_t k = 0; k < res6.shape()[2]; ++k)
        choreo::choreo_assert(float(a6[i][j][k]) == float(res6[i][j][k]),
                              "values are not equal.");

  std::cout << "Test async_copy_f6 Passed\n" << std::endl;

  auto a4 = choreo::make_spandata<choreo::f4_e2m1>(6, 17, 32);
  a4.fill_random(-2.0f, 2.0f);

  auto res4 = dma_copy_f4(a4.view());

  for (size_t i = 0; i < res4.shape()[0]; ++i)
    for (size_t j = 0; j < res4.shape()[1]; ++j)
      for (size_t k = 0; k < res4.shape()[2]; ++k)
        choreo::choreo_assert(float(a4[i][j][k]) == float(res4[i][j][k]),
                              "values are not equal.");

  std::cout << "Test async_copy_f4 Passed\n" << std::endl;
}

// CHECK-NOT: choreo-rt
// CHECK: Test async_copy_f6 Passed
// CHECK-NOT: choreo-rt
// CHECK: Test async_copy_f4 Passed
