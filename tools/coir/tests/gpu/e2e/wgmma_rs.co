// REQUIRES: TARGET-SM_90A
// RUN: cocc -t cute -es -arch=sm_90a %s 2>&1 | FileCheck %s
// RUN: cocc -t cute -gs -arch=sm_90a %s | bash -s -- --execute | FileCheck --match-full-lines --check-prefix=EXEC %s
//
// WGMMA RS mode: A from registers, B from shared memory.
// Since a_frag is filled with 0, output = 0 * B = 0 regardless of B values.

#define WARP_M 64
#define WARP_N 64
#define WARP_K 16

__co__ auto rs_zero(f16 [WARP_N, WARP_K] rhs) {
  f32 [WARP_M, WARP_N] output{0.0f};
  parallel {bm, bn} by [1, 1] : block {
    mc = mma.fill.f32 0.0f;
    frag f16[WARP_M, WARP_K] a_frag {0.0f};
    rhs_s = tma.copy rhs.subspan(WARP_N, WARP_K).at(bn, 0) => shared;
    parallel p by 1 : group-4 {
      mb = mma.load rhs_s;
      mma.row.row mc, a_frag, mb;
    }
    mma.store mc, output.chunkat(bm, bn);
  }
  return output;
}

int main() {
  auto rhs = choreo::make_spandata<choreo::f16>(WARP_N, WARP_K);
  rhs.fill_random(1.0f, 10.0f);

  auto res = rs_zero(rhs.view());

  bool pass = true;
  for (int i = 0; i < WARP_M; ++i)
    for (int j = 0; j < WARP_N; ++j)
      if (std::abs(float(res[i][j])) > 1e-4f)
        pass = false;

  if (pass) std::cout << "WGMMA RS Test Passed" << std::endl;
  else std::cout << "FAIL: wgmma_rs" << std::endl;
}

// CHECK: float v{{[0-9]+}}[32]
// CHECK: half v{{[0-9]+}}[8]
// CHECK: wgmma_make_smem_desc<WGMMA_MajorOrder::K_MAJOR, WGMMA_Swizzle::NS>
// CHECK: warpgroup_fence_operand
// CHECK: warpgroup_arrive
// CHECK: MMA_64x64x16_F32F16F16_RS
// CHECK: warpgroup_commit_batch
// CHECK: warpgroup_wait
// CHECK: store_fragment_d<CUTE_WGMMA_M64K16
// EXEC: WGMMA RS Test Passed
