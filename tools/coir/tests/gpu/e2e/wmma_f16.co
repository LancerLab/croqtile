// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s -o %s.result && bash %s.result --execute | FileCheck --match-full-lines %s && rm -f %s.result
// RUN: cocc -t gpu -gs %s -o %s.gpu.result && bash %s.gpu.result --execute | FileCheck --match-full-lines --check-prefix=GPU %s && rm -f %s.gpu.result
//
// WMMA f16 matmul: 2x2 group, row.col layout.

#define M 128
#define N 256
#define K 256

__co__ auto matmul_group_rc(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

int main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(K, N);
  lhs.fill_random(1.0f, 10.0f);
  rhs.fill_random(1.0f, 10.0f);

  auto res = matmul_group_rc(lhs.view(), rhs.view());

  float tolerance = 0.005f;
  bool pass = true;
  for (int i = 0; i < M; ++i)
    for (int j = 0; j < N; ++j) {
      float ref = 0.0f;
      for (int k = 0; k < K; ++k)
        ref += float(lhs[i][k]) * float(rhs[k][j]);
      auto delta = std::abs((ref - float(res[i][j])) / ref);
      if (delta >= tolerance) pass = false;
    }

  if (pass) std::cout << "WMMA F16 Test Passed" << std::endl;
  else std::cout << "FAIL: wmma_f16" << std::endl;
}

// CHECK: WMMA F16 Test Passed
// GPU: WMMA F16 Test Passed
