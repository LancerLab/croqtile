// REQUIRES: TARGET-SM_90A
// RUN: cocc -t cute -es -arch=sm_90a %s 2>&1 | FileCheck %s
// RUN: cocc -t cute -gs -arch=sm_90a %s | bash -s -- --execute | FileCheck --match-full-lines --check-prefix=EXEC %s
//
// WGMMA SS mode with K-loop: accumulates across multiple K tiles.
// Tests: foreach loop, multiple TMA loads per iteration, swizzled descriptors.

#define M 64
#define N 64
#define K 32
#define TILE_K 16

__co__ auto wgmma_kloop(f16 [M, K] lhs, f16 [N, K] rhs) {
  f32 [M, N] output{0.0f};
  parallel {bm, bn} by [1, 1] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      lhs_s = tma.copy.swiz<32> lhs.subspan(M, TILE_K).at(bm, iv_k) => shared;
      rhs_s = tma.copy.swiz<32> rhs.subspan(N, TILE_K).at(bn, iv_k) => shared;
      parallel p by 1 : group-4 {
        ma = mma.load.swiz<32> lhs_s;
        mb = mma.load.swiz<32> rhs_s;
        mma.row.row mc, ma, mb;
      }
    }
    mma.store mc, output.chunkat(bm, bn);
  }
  return output;
}

int main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(N, K);

  // A=1, B=1 => C = A * B^T = K * ones(M,N) = 32
  lhs.fill(1.0f);
  rhs.fill(1.0f);

  auto res = wgmma_kloop(lhs.view(), rhs.view());

  float expected = (float)K;
  bool pass = true;
  for (int i = 0; i < M; ++i)
    for (int j = 0; j < N; ++j)
      if (std::abs(float(res[i][j]) - expected) > 1e-1f)
        pass = false;

  if (pass) std::cout << "WGMMA K-loop Test Passed" << std::endl;
  else std::cout << "FAIL: wgmma_kloop" << std::endl;
}

// CHECK: wgmma_make_smem_desc<WGMMA_MajorOrder::K_MAJOR, WGMMA_Swizzle::B32>
// CHECK: MMA_64x64x16_F32F16F16_SS
// CHECK: CU_TENSOR_MAP_SWIZZLE_32B
// EXEC: WGMMA K-loop Test Passed
