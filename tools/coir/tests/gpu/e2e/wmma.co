// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
// RUN: cocc -t gpu -gs %s | bash -s -- --execute | FileCheck --match-full-lines --check-prefix=GPU %s
//
// WMMA matrix multiply (f16 input, f32 accumulator).

#define M 32
#define N 32
#define K 16

__co__ auto wmma_matmul(f16 [M, K] lhs, f16 [K, N] rhs) {
  f32 [M, N] output;
  parallel {m, n} by [M / 16, N / 16] : block {
    mc = mma.fill.f32 0.0;
    parallel g by 1 : group {
      foreach k in K / 16 {
        ma = mma.load lhs.chunkat(m, k);
        mb = mma.load rhs.chunkat(k, n);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m, n);
    }
  }
  return output;
}

int main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(K, N);
  lhs.fill(choreo::f16(1.0f));
  rhs.fill(choreo::f16(1.0f));

  auto res = wmma_matmul(lhs.view(), rhs.view());

  bool pass = true;
  for (int i = 0; i < M; ++i)
    for (int j = 0; j < N; ++j)
      if (std::abs(res[i][j] - float(K)) > 0.01f)
        pass = false;

  if (pass) std::cout << "PASS: wmma" << std::endl;
  else std::cout << "FAIL: wmma" << std::endl;
}

// CHECK: PASS: wmma
// GPU: PASS: wmma
