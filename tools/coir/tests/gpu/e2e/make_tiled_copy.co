// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s

#include "choreo.h"

__co__ auto ele_add0(s32 [16, 32] lhs, s32 [16, 32] rhs) {
  s32[lhs.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      lhs_s = dma.copy lhs => shared;
      rhs_s = dma.copy rhs => shared;
      foreach {x, y} in lhs_s.span {
        lhs_s.data.at(x, y) += rhs_s.data.at(x, y);
      }
      dma.copy lhs_s => output;
    }

  return output;
}

int main() {
  auto a = choreo::make_spandata<choreo::s32>(16, 32);
  auto b = choreo::make_spandata<choreo::s32>(16, 32);
  a.fill_random(-10, 10);
  b.fill_random(-10, 10);

  auto res = ele_add0(a.view(), b.view());
  for (size_t i = 0; i < 16; ++i)
    for (size_t j = 0; j < 32; ++j)
      choreo::choreo_assert(a[i][j] + b[i][j] == res[i][j], "mismatch");
  std::cout << "Test Passed" << std::endl;
}

// CHECK: Test Passed
