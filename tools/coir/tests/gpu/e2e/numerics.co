// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s -o %s.result && bash %s.result --execute | FileCheck --match-full-lines %s && rm -f %s.result
// RUN: cocc -t gpu -es %s | FileCheck --check-prefix=PTX %s
//
// Numeric operations: add, sub, mul with various types.

__co__ f32 [64] fma_kernel(f32 [64] a, f32 [64] b, f32 [64] c) {
  f32[a.span] out;
  parallel p by 64
    out.at(p) = a.at(p) * b.at(p) + c.at(p);
  return out;
}

int main() {
  auto a = choreo::make_spandata<choreo::f32>(64);
  auto b = choreo::make_spandata<choreo::f32>(64);
  auto c = choreo::make_spandata<choreo::f32>(64);
  a.fill_random(-5.0f, 5.0f);
  b.fill_random(-5.0f, 5.0f);
  c.fill_random(-5.0f, 5.0f);

  auto res = fma_kernel(a.view(), b.view(), c.view());

  for (size_t i = 0; i < 64; ++i) {
    float expected = a[i] * b[i] + c[i];
    choreo::choreo_assert(std::abs(expected - res[i]) < 1e-4f, "fma mismatch");
  }

  std::cout << "PASS: numerics" << std::endl;
}

// CHECK: PASS: numerics
// PTX: .visible .entry fma_kernel_kernel
