// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s -o %s.result && bash %s.result --execute | FileCheck --match-full-lines %s && rm -f %s.result
// RUN: cocc -t gpu -gs %s -o %s.gpu.sh && bash %s.gpu.sh --execute | FileCheck --check-prefix=GPU --match-full-lines %s && rm -f %s.gpu.sh

__co__ s32 [16, 16] matmul_basic(s32 [16, 16] lhs, s32 [16, 16] rhs) {
  s32 [16, 16] output;
  parallel m by 16 : block
    parallel n by 16 : thread
      foreach k in 16
        output.at(m, n) += lhs.at(m, k) * rhs.at(k, n);
  return output;
}

int main() {
  auto a = choreo::make_spandata<choreo::s32>(16, 16);
  auto b = choreo::make_spandata<choreo::s32>(16, 16);
  a.fill_random(-5, 5);
  b.fill_random(-5, 5);
  auto c = matmul_basic(a.view(), b.view());

  bool pass = true;
  for (int i = 0; i < 16 && pass; ++i)
    for (int j = 0; j < 16 && pass; ++j) {
      int sum = 0;
      for (int k = 0; k < 16; ++k) sum += a[i][k] * b[k][j];
      if (c[i][j] != sum) pass = false;
    }
  if (pass) std::cout << "Matmul S32 Test Passed" << std::endl;
  else std::cout << "Matmul S32 Test FAILED" << std::endl;
}

// CHECK: Matmul S32 Test Passed
// GPU: Matmul S32 Test Passed
