// REQUIRES: TARGET-GPU
// RUN: cocc -t cute -gs %s -o %s.result && bash %s.result --execute | FileCheck %s && rm -f %s.result

__co__ auto addone(f32[6, 256] data, stream _s) {
  f32[data.span] output;
  parallel<_s> p by 6 : block {
    parallel q by 256 : thread {
      output.at(p, q) = data.at(p, q) + 1.0f;
    }
  }
  return output;
}

int main() {
  cudaStream_t s;
  cudaStreamCreate(&s);
  auto d = choreo::make_spandata<choreo::f32>(6, 256);
  d.fill(1.0f);
  auto result = addone(d.view(), s);
  bool ok = true;
  for (int i = 0; i < 6 * 256; ++i)
    if (result.data()[i] != 2.0f) { ok = false; break; }
  std::cout << (ok ? "Stream test passed" : "FAIL") << std::endl;
  cudaStreamDestroy(s);
}

// CHECK: Stream test passed
