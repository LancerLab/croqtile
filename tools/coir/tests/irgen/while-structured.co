// RUN: co2ir %s | FileCheck %s

// IRGen test: simple while loop without break/continue lowers to scf.while
// with iter_args, scf.condition, and scf.yield.

// CHECK: coir.kernel
// CHECK: scf.while
// CHECK: arith.cmpi
// CHECK: scf.condition
// CHECK: scf.yield

__co__ void test_while(s32 [64] buf, s32 N) {
  parallel p by 64 {
    mutable s32 i = 0;
    while (i < N) {
      buf.at(p) = i;
      i = i + 1;
    }
  }
}
