// RUN: co2ir %s | FileCheck %s

// IRGen test: if-without-else creates an implicit else that yields the
// pre-if value, producing a proper SSA merge.

// CHECK: coir.kernel
// CHECK: scf.if
// CHECK-SAME: -> (i32)
// CHECK: scf.yield
// The implicit else region yields the original value:
// CHECK: scf.yield
// CHECK: coir.tensor.store_elem

__co__ void test_if_no_else(s32 [64] buf, s32 N) {
  parallel p by 64 {
    mutable s32 x = 5;
    if (N > 10)
      x = 42;
    buf.at(p) = x;
  }
}
