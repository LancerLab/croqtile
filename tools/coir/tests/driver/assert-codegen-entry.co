// RUN: cocc -t cute -es -rtc=all %s 2>&1 | FileCheck %s
//
// Test that COIR emits device-side assertions for thread-level element access.
// The parallel index (threadIdx.x) is a thread-level value, so assertions
// stay in device code as choreo_assert rather than being hoisted to host.

__co__ void double_it(s32 [128] x) {
  s32[128] y;
  parallel p by 128
    y.at(p) = x.at(p) * 2;
}

// Device code: bounds checks on thread index.
// CHECK: choreo::choreo_assert({{.*}}element access 'x' should be >= 0
// CHECK: choreo::choreo_assert({{.*}}element access 'x' should be < 128
// CHECK: choreo::choreo_assert({{.*}}element access 'y' should be >= 0
