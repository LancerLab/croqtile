// RUN: cocc -t cute -es -rtc=all %s 2>&1 | FileCheck %s
//
// Test that COIR does NOT emit runtime assertions when the index is a
// parallel variable with a compile-time-known bound (SBE proves p >= 0
// and p < 128 statically).  This verifies the SBE resolution path.

__co__ void double_it(s32 [128] x) {
  s32[128] y;
  parallel p by 128
    y.at(p) = x.at(p) * 2;
}

// No element-access assertions emitted -- SBE proves them statically.
// CHECK-NOT: choreo_assert
// CHECK-NOT: runtime_check
