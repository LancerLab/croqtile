// REQUIRES: TARGET-AMDGPU
// RUN: choreo -gs %target %amdgpu_arch %s | bash -s -- --execute | FileCheck --match-full-lines %s

__co__ s32 [6, 64] ele_add(s32 [6, 64] lhs, s32 [6, 64] rhs) {
  s32[lhs.span] output;

  parallel p by 6, q by 64
    output.at(p, q) = lhs.at(p, q) + rhs.at(p, q);

  return output;
}

__co__ s32 [128] ele_sub(s32 [128] lhs, s32 [128] rhs) {
  s32[lhs.span] output;

  parallel i by 128
    output.at(i) = lhs.at(i) - rhs.at(i);

  return output;
}

int main() {
  {
    auto a = choreo::make_spandata<choreo::s32>(6, 64);
    auto b = choreo::make_spandata<choreo::s32>(6, 64);
    for (size_t i = 0; i < 6; ++i)
      for (size_t j = 0; j < 64; ++j) {
        a[i][j] = i * 64 + j;
        b[i][j] = 1;
      }

    auto res = ele_add(a.view(), b.view());

    for (size_t i = 0; i < 6; ++i)
      for (size_t j = 0; j < 64; ++j)
        choreo::choreo_assert(
            res[i][j] == (int)(i * 64 + j + 1),
            "ele_add: values are not equal.");

    std::cout << "Test ele_add Passed" << std::endl;
  }

  {
    auto a = choreo::make_spandata<choreo::s32>(128);
    auto b = choreo::make_spandata<choreo::s32>(128);
    for (size_t i = 0; i < 128; ++i) {
      a[i] = (int)(i * 3);
      b[i] = (int)i;
    }

    auto res = ele_sub(a.view(), b.view());

    for (size_t i = 0; i < 128; ++i)
      choreo::choreo_assert(
          res[i] == (int)(i * 2),
          "ele_sub: values are not equal.");

    std::cout << "Test ele_sub Passed" << std::endl;
  }
}

// CHECK: Test ele_add Passed
// CHECK: Test ele_sub Passed
