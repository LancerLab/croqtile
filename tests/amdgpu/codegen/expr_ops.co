// TODORUN: choreo -es -n -t hip -arch=gfx1030 %s 2>&1 | FileCheck %s

// --- Float32 literal with f suffix ---
__co__ void float_suffix_test(f32 [16] a) {
  parallel p by 16 : thread {
    a.at(p) = 1.5f;
  }
}

// CHECK: 1.500000f

// --- CeilDiv via cdiv ---
__co__ void cdiv_test(f32 [64] a) {
  int N = 64;
  int B = 16;
  int NB = cdiv(N, B);
  parallel p by NB : thread {
    a.at(p) = 0.0;
  }
}

// CHECK: ((N + B - 1) / B)
