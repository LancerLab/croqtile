// RUN: choreo -es -t cute -arch=sm_86 -fsmem-align=128 %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=CHECK --allow-empty

#include "choreo.h"

__co__ auto f0(s8[M, N] input) {
  parallel p by 1 : block {
    foreach {x, y} in [4, 4] {
      s = dma.copy input.subspan(128, 128).at(x, y) => shared;
      parallel q by 16 : thread {}
    }
  }
}

__co__ auto f1(u8[M, N] input, int thr_cnt) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.subspan(128, 128).at(x, y) => shared;
      parallel q by thr_cnt : thread {}
    }
}

__co__ auto f3(u8[128, 128] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.span_as(4, 32, 128).subspan(1, 8, _).at(x, y, 0) => shared;
      parallel q by 128 : thread {}
    }
}

__co__ auto f4(u8[M, N] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.chunkat(x, y) => shared;
      parallel q by 1 : group {}
    }
}
// CHECK: info: In the current kernel `__choreo_device_f4`, cudaFuncAttributeMaxDynamicSharedMemorySize is set

__co__ auto f5(u8[M, N] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.view(128, 128 : M, 2).from(x, y) => shared;
      parallel q by 128 : thread {}
    }
}

__co__ auto f6(u8[M, N] input, int strd) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.view(128, 128 : M, strd).from(x, y) => shared;
      parallel q by 128 : thread {}
    }
}

__co__ auto f7(u8[128, 126] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 2] {
      s = dma.copy input.subspan(32, 63).at(x, y) => shared;
      parallel q by 128 : thread {}
    }
}

__co__ auto foo8(u8[128, 128] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.subspan(32, 32).at(x, y) => shared;
      parallel q by 127 : thread {}
    }
}

__co__ auto f9(u8[128, 128] input) {
  parallel p by 1 : block
    foreach {x, y} in [4, 4] {
      s = dma.copy input.subspan(33, 32).at(x, y) => shared;
      parallel q by 128 : thread {}
    }
}
