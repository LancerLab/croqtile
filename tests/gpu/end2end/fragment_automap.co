// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define LEN 1024
#define N 64
#define M 32

__co__ f32 [N] fragment_automap_1d() {
  f32[N] out;
  parallel t by 128 : thread {
    fragment f32[LEN] buf {0.0f};
    frag.apply buf, [](i) { return __to<f32>(i) * 2.0f; };
    frag.store out, buf;
  }
  return out;
}

__co__ f32 [M, M] fragment_automap_2d() {
  f32[M, M] out;
  parallel t by 128 : thread {
    fragment f32[M, M] tile {0.0f};
    frag.apply tile, [](i, j) { return __to<f32>(i * M + j); };
    frag.store out, tile;
  }
  return out;
}

int main() {
  {
    auto out = fragment_automap_1d();
    for (size_t i = 0; i < N; ++i) {
      auto expect = (float)i * 2.0f;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "1d fragment automap mismatch.");
    }
    std::cout << "Test fragment_automap_1d Passed\n" << std::endl;
  }

  {
    auto out = fragment_automap_2d();
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < M; ++j) {
        auto expect = (float)(i * M + j);
        if (out[i][j] != expect)
          choreo::choreo_assert(out[i][j] == expect,
                                  "2d fragment automap mismatch.");
      }
    std::cout << "Test fragment_automap_2d Passed\n" << std::endl;
  }
}

// CHECK: Test fragment_automap_1d Passed
// CHECK: Test fragment_automap_2d Passed
