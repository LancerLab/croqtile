// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute %cuda_arch %s -o %s.cute.result && CHOREO_DISABLE_TIMING=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define M 64
#define N 64
#define K 64

// Test: GEMM -> row-wise softmax -> store.
// softmax: reduce_max -> subtract max -> exp -> reduce_sum -> divide.
// Verifies frag.reduce and frag.apply (incl. __exp built-in) with
// cross-fragment 1D broadcast on WGMMA_ACC layout.
__co__ auto reduce_and_normalize_on_acc(f16[M, K] lhs, f16[K, N] rhs) {
  f16[M, N] output;

  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      lhs_s = dma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => shared;
      rhs_s = dma.copy.swiz<128> rhs.chunkat(iv_k, block_n) => shared;
      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<128> lhs_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_s.chunkat(iv_warp, _);
          mma.row.col mc, ma, mb;

          // Row-wise reduce + normalize (same group-4 scope as MMA).
          fragment f32[M] row_max;
          fragment f32[M] row_sum;

          frag.reduce_max mc, row_max, 1;
          frag.apply mc, [](i, j) { return __exp(mc.at(i, j) - row_max.at(i)); };
          frag.reduce_sum mc, row_sum, 1;
          frag.apply mc, [](i, j) { return mc.at(i, j) / row_sum.at(i); };
        }
      }
    }
    mma.store mc, output.chunkat(block_m, block_n);
  }

  return output;
}

int main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(K, N);
  for (int i = 0; i < M; i++)
    for (int k = 0; k < K; k++)
      lhs[i][k] = __float2half(1.0f);
  for (int k = 0; k < K; k++)
    for (int j = 0; j < N; j++)
      rhs[k][j] = __float2half((float)(j + 1));

  auto res = reduce_and_normalize_on_acc(lhs.view(), rhs.view());

  // Reference softmax: C[i][j] = sum_k 1.0*(j+1) = K*(j+1).
  // softmax(C)[i][j] = exp(C[i][j] - max_j C[i][j]) / sum_j exp(C[i][j] - max_j C[i][j]).
  float ref_vals[N];
  float ref_max = -1e30f;
  for (int j = 0; j < N; j++) {
    ref_vals[j] = K * (j + 1.0f);
    if (ref_vals[j] > ref_max) ref_max = ref_vals[j];
  }
  float ref_exp[N];
  float ref_sum = 0;
  for (int j = 0; j < N; j++) {
    ref_exp[j] = expf(ref_vals[j] - ref_max);
    ref_sum += ref_exp[j];
  }

  float tolerance = 0.01f;
  for (int i = 0; i < M; i++) {
    for (int j = 0; j < N; j++) {
      float expected = ref_exp[j] / ref_sum;
      float got = __half2float(res[i][j]);
      float delta = fabsf(expected - got);
      if (delta >= tolerance)
        std::cout << "[" << i << "," << j << "] expected=" << expected
                  << " got=" << got << " delta=" << delta << "\n";
      choreo::choreo_assert(delta < tolerance, "softmax mismatch");
    }
  }

  std::cout << "Test reduce_and_normalize_on_acc Passed\n";
}

// CHECK: Test reduce_and_normalize_on_acc Passed
