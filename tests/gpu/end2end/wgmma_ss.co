// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute %cuda_arch %s -o %s.cute.result && CHOREO_DISABLE_TIMING=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result
//
// Non-persistent WGMMA shared/shared coverage.

// Consolidated from: matmul_e4m3_dynamic.co, matmul_f16_dynamic.co

// --- matmul_e4m3_dynamic.co: WGMMA f8_e4m3 row.row ---
__co__ void matmul_e4m3(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs, global f32 [M, N] output) {
  int WARP_M = 64, WARP_N = 64, TILE_K = 32, WARP_K = 32;

  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f8_e4m3 [WARP_M, TILE_K] lhs_load_s;
    shared f8_e4m3 [WARP_N, TILE_K] rhs_load_s;

    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      dma.copy.swiz<32> lhs.subspan(WARP_M, TILE_K).step(WARP_M, TILE_K).at(block_m, iv_k) => lhs_load_s;
      dma.copy.swiz<32> rhs.chunkat(block_n, iv_k) => rhs_load_s;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }

    shared f32 [WARP_M, WARP_N] output_s;
    mma.store mc, output_s;

    dma.copy output_s => output.subspan(WARP_M, WARP_N).step(WARP_M, WARP_N).at(block_m, block_n);
  }
}

// --- matmul_f16_dynamic.co: WGMMA f16 row.row ---
__co__ void matmul_f16(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f16 [WARP_M, TILE_K] lhs_load_s;
    shared f16 [WARP_N, TILE_K] rhs_load_s;
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      dma.copy.swiz<128> lhs.subspan(WARP_M, TILE_K).at(block_m, iv_k) => lhs_load_s;
      dma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }

    shared f16 [WARP_M, WARP_N] output_s;
    mma.store mc, output_s;

    dma.copy output_s => output.subspan(WARP_M, WARP_N).at(block_m, block_n);
  }
}

static bool check_timing_disabled(int argc, char** argv) {
  auto is_disable_timing_arg = [](const char* s) {
    const char* t = "--disable-timing";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i)
    if (is_disable_timing_arg(argv[i])) return true;
  const char* env = std::getenv("CHOREO_DISABLE_TIMING");
  return env && env[0] == '1' && env[1] == '\0';
}

void wgmma_dynamic_main(int argc, char** argv) {
  bool enable_timing = !check_timing_disabled(argc, argv);

  size_t M = 768, N = 512, K = 512;

  {
    auto lhs_h = choreo::make_spandata<choreo::f8_e4m3>(M, K);
    auto rhs_h = choreo::make_spandata<choreo::f8_e4m3>(N, K);
    auto res_h = choreo::make_spandata<float>(M, N);
    lhs_h.fill_random(0, 2);
    rhs_h.fill_random(0, 2);
    res_h.fill(0.0f);

    __nv_fp8_e4m3 *a_d = nullptr, *b_d = nullptr;
    float *c_d = nullptr;
    cudaMalloc(&a_d, M * K * sizeof(__nv_fp8_e4m3));
    cudaMalloc(&b_d, N * K * sizeof(__nv_fp8_e4m3));
    cudaMalloc(&c_d, M * N * sizeof(float));
    cudaMemcpy(a_d, lhs_h.data(), M * K * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice);
    cudaMemcpy(b_d, rhs_h.data(), N * K * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice);
    cudaMemcpy(c_d, res_h.data(), M * N * sizeof(float), cudaMemcpyHostToDevice);

    auto lhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K});
    auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
    auto res_d = choreo::make_spanview<float, 2>(c_d, {M, N});

    if (enable_timing) {
      choreo::TimerOption topt;
      topt.warmup = 10;
      topt.repeat = 50;
      auto avg_ms = choreo::timing([&]() { matmul_e4m3(lhs_d, rhs_d, res_d); cudaDeviceSynchronize(); }, topt);
      std::cout << "Timing avg ms: " << avg_ms << "\n";
    } else {
      matmul_e4m3(lhs_d, rhs_d, res_d);
    }

    cudaMemcpy(res_h.data(), c_d, M * N * sizeof(float), cudaMemcpyDeviceToHost);

    float base_tol = 0.3f;
    float rel_tol = 0.05f;
    choreo::verify_matmul_row_row_subset(lhs_h, rhs_h, res_h, base_tol, rel_tol, 8, 8);
    std::cout << "Test e4m3 Passed\n" << std::endl;

    cudaFree(a_d); cudaFree(b_d); cudaFree(c_d);
  }

  {
    auto lhs_h = choreo::make_spandata<choreo::f16>(M, K);
    auto rhs_h = choreo::make_spandata<choreo::f16>(N, K);
    auto res_h = choreo::make_spandata<choreo::f16>(M, N);
    lhs_h.fill_random(0, 2);
    rhs_h.fill_random(0, 2);
    res_h.fill(0.0f);

    half *a_d = nullptr, *b_d = nullptr, *c_d = nullptr;
    cudaMalloc(&a_d, M * K * sizeof(half));
    cudaMalloc(&b_d, N * K * sizeof(half));
    cudaMalloc(&c_d, M * N * sizeof(half));
    cudaMemcpy(a_d, lhs_h.data(), M * K * sizeof(half), cudaMemcpyHostToDevice);
    cudaMemcpy(b_d, rhs_h.data(), N * K * sizeof(half), cudaMemcpyHostToDevice);
    cudaMemcpy(c_d, res_h.data(), M * N * sizeof(half), cudaMemcpyHostToDevice);
    cudaDeviceSynchronize();

    auto lhs_d = choreo::make_spanview<choreo::f16, 2>(a_d, {M, K});
    auto rhs_d = choreo::make_spanview<choreo::f16, 2>(b_d, {N, K});
    auto res_d = choreo::make_spanview<choreo::f16, 2>(c_d, {M, N});

    if (enable_timing) {
      choreo::TimerOption topt;
      topt.warmup = 10;
      topt.repeat = 50;
      auto avg_ms = choreo::timing([&]() { matmul_f16(lhs_d, rhs_d, res_d); cudaDeviceSynchronize(); }, topt);
      std::cout << "Timing avg ms: " << avg_ms << "\n";
    } else {
      matmul_f16(lhs_d, rhs_d, res_d);
    }

    cudaMemcpy(res_h.data(), c_d, M * N * sizeof(half), cudaMemcpyDeviceToHost);
    cudaDeviceSynchronize();

    float tolerance = 0.005f;
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < N; ++j) {
        auto ref = 0.0f;
        for (size_t k = 0; k < lhs_h.shape()[1]; ++k)
          ref += __half2float(lhs_h[i][k] * rhs_h[j][k]);
        auto delta = std::abs((ref - __half2float(res_h[i][j])) / ref);
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << __half2float(res_h[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test f16 Passed\n" << std::endl;

    cudaFree(a_d); cudaFree(b_d); cudaFree(c_d);
  }
}


#undef M
#undef N
#undef K

#define M 64
#define N 64
#define K 64

__co__ auto matmul_kmn(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output{0.0f};

  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      lhs_s = dma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => shared;
      rhs_s = dma.copy.swiz<128> rhs.chunkat(iv_k, block_n) => shared;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_s.chunkat(iv_warp, _);
          mma.row.col mc, ma, mb;
        }
      }
    }
    mma.store mc, output.chunkat(block_m, block_n);
  }

  return output;
}

void wgmma_kmn_main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(K, N);
  lhs.fill_random(0.0f, 2.0f);
  rhs.fill_random(0.0f, 2.0f);

  auto res = matmul_kmn(lhs.view(), rhs.view());

  float base_tol = 0.05f;
  float rel_tol = 0.02f;
  choreo::verify_matmul_row_col_subset(lhs, rhs, res, base_tol, rel_tol, 8, 8);

  std::cout << "Test Passed\n" << std::endl;
}


#undef M
#undef N
#undef K

#define WARP_M 64
#define WARP_N 128
#define TILE_K 128
#define WARP_K 32

#define M 128
#define N 128
#define K 128

__co__ void matmul_fp8_ss(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs,
                   global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f8_e4m3 [WARP_M, TILE_K] lhs_s;
    shared f8_e4m3 [WARP_N, TILE_K] rhs_s;
    mc = mma.fill.f16 0.0f;

    foreach {iv_k} in [cdiv(K, TILE_K)] {
      tma.copy.swiz<128> lhs.subspan(WARP_M, TILE_K).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_s;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }

    shared f16 [WARP_M, WARP_N] output_s;
    mma.store mc, output_s;
    tma.copy output_s => output.subspan(WARP_M, WARP_N).at(block_m, block_n);
  }
}

void wgmma_fp8_main() {
  auto lhs_h = choreo::make_spandata<choreo::f8_e4m3>(M, K);
  auto rhs_h = choreo::make_spandata<choreo::f8_e4m3>(N, K);
  auto res_h = choreo::make_spandata<choreo::f16>(M, N);
  lhs_h.fill_random(0.0f, 2.0f);
  rhs_h.fill_random(0.0f, 2.0f);
  res_h.fill(0.0f);

  __nv_fp8_e4m3* a_d = nullptr;
  __nv_fp8_e4m3* b_d = nullptr;
  half* c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, M * K * sizeof(__nv_fp8_e4m3)));
  choreo::abend_true(cudaMalloc(&b_d, N * K * sizeof(__nv_fp8_e4m3)));
  choreo::abend_true(cudaMalloc(&c_d, M * N * sizeof(half)));

  choreo::abend_true(cudaMemcpy(a_d, lhs_h.data(), M * K * sizeof(__nv_fp8_e4m3),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs_h.data(), N * K * sizeof(__nv_fp8_e4m3),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(
      cudaMemcpy(c_d, res_h.data(), M * N * sizeof(half), cudaMemcpyHostToDevice));

  auto lhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K});
  auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
  auto res_d = choreo::make_spanview<choreo::f16, 2>(c_d, {M, N});

  matmul_fp8_ss(lhs_d, rhs_d, res_d);
  choreo::abend_true(cudaDeviceSynchronize());
  choreo::abend_true(
      cudaMemcpy(res_h.data(), c_d, M * N * sizeof(half), cudaMemcpyDeviceToHost));

  float base_tol = 0.3f;
  float rel_tol = 0.05f;
  choreo::verify_matmul_row_row_subset(lhs_h, rhs_h, res_h, base_tol, rel_tol,
                                       8, 8);

  std::cout << "Test Passed\n" << std::endl;
}


#pragma push_macro("M")
#pragma push_macro("N")
#pragma push_macro("K")
#undef M
#undef N
#undef K

// Migrated matmul coverage.
__co__ void matmul_e4m3_sm90(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f8_e4m3 [64, 128] lhs_load_s;
    shared f8_e4m3 [128, 128] rhs_load_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 128)] {
      tma.copy.swiz<128> lhs.subspan(64, 128).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      foreach {iv_warp} in [cdiv(128, 32)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }
    shared f16 [64, 128] output_s;
    mma.store mc, output_s;
    tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
  }
}

__co__ void matmul_e4m3_mwg_sm90(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 128), cdiv(N, 64)] : block {
    shared f8_e4m3 [128, 128] lhs_load_s;
    shared f8_e4m3 [64, 128] rhs_load_s;
    shared f16 [128, 64] output_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 128)] {
      tma.copy.swiz<128> lhs.subspan(128, 128).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      parallel p1 by 2 : group-4 {
        foreach {iv_warp} in [cdiv(128, 32)] {
          ma = mma.desc lhs_load_s.chunkat(p1, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
        if (iv_k == cdiv(K, 128) - 1)
          mma.store mc, output_s.chunkat(p1, _);
      }
    }
    tma.copy output_s => output.subspan(128, 64).at(block_m, block_n);
  }
}

__co__ void matmul_e4m3_mwg_tbc_sm90(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs, global f16 [M, N] output) {
  parallel {cm} by [4] : cluster {
    parallel {block_m, block_n} by [cdiv(M, 128), cdiv(N, 64)] : block {
      shared f8_e4m3 [128, 128] lhs_load_s;
      shared f8_e4m3 [64, 128] rhs_load_s;
      shared f16 [128, 64] output_s;
      mc = mma.fill.f16 0.0f;
      foreach {iv_k} in [cdiv(K, 128)] {
        tma.copy.swiz<128> lhs.subspan(128, 128).at(block_m, iv_k) => lhs_load_s;
        tma.copy.multicast.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        parallel p1 by 2 : group-4 {
          foreach {iv_warp} in [cdiv(128, 32)] {
            ma = mma.desc lhs_load_s.chunkat(p1, iv_warp);
            mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
            mma.row.row mc, ma, mb;
          }
          if (iv_k == cdiv(K, 128) - 1)
            mma.store mc, output_s.chunkat(p1, _);
        }
      }
      tma.copy output_s => output.subspan(128, 64).at(block_m, block_n);
    }
  }
}

__co__ void blockscale_gemm_e4m3_n48(global f8_e4m3 [M, K] lhs,
                                      global f32 [M, DIV_BLK_K] scale_lhs,
                                      global f8_e4m3 [N, K] rhs,
                                      global f32 [DIV_BLK_N, DIV_BLK_K] scale_rhs,
                                      global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 48)] : block {
    shared f8_e4m3 [64, 128] lhs_load_s;
    shared f8_e4m3 [48, 128] rhs_load_s;
    parallel p by 1 : group-4 {
      mc = mma.fill.f16 0.0f;
      foreach {iv_k} in [cdiv(K, 128)] {
        tma.copy.swiz<128> lhs.subspan(64, 128).at(block_m, iv_k) => lhs_load_s;
        tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        foreach {iv_warp} in [cdiv(128, 32)] {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row.scale mc, ma, mb, scale_lhs.subspan(64, 1).at(block_m, iv_k), scale_rhs.at(block_n, iv_k);
        }
      }
      shared f16 [64, 48] output_s;
      mma.store mc, output_s;
      tma.copy output_s => output.subspan(64, 48).at(block_m, block_n);
    }
  }
}

__co__ void matmul_f16_sm90(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f16 [64, 64] lhs_load_s;
    shared f16 [128, 64] rhs_load_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs.subspan(64, 64).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      foreach {iv_warp} in [cdiv(64, 16)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }
    shared f16 [64, 128] output_s;
    mma.store mc, output_s;
    tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
  }
}

__co__ void matmul_f16_sm90_n96(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 96)] : block {
    shared f16 [64, 64] lhs_load_s;
    shared f16 [96, 64] rhs_load_s;
    parallel p by 1 : group-4 {
      mc = mma.fill.f16 0.0f;
      foreach {iv_k} in [cdiv(K, 64)] {
        dma.copy.swiz<128> lhs.subspan(64, 64).at(block_m, iv_k) => lhs_load_s;
        dma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        foreach {iv_warp} in [cdiv(64, 16)] {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
      shared f16 [64, 96] output_s;
      mma.store mc, output_s;
      dma.copy output_s => output.subspan(64, 96).at(block_m, block_n);
    }
  }
}

__co__ void matmul_f16_sm90_tbc(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {cm} by [2] : cluster {
    parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
      shared f16 [64, 64] lhs_load_s;
      shared f16 [128, 64] rhs_load_s;
      mc = mma.fill.f16 0.0f;
      foreach {iv_k} in [cdiv(K, 64)] {
        tma.copy.swiz<128> lhs.subspan(64, 64).at(block_m, iv_k) => lhs_load_s;
        tma.copy.multicast.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        foreach {iv_warp} in [cdiv(64, 16)] {
          parallel p by 1 : group-4 {
            ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
            mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
            mma.row.row mc, ma, mb;
          }
        }
      }
      shared f16 [64, 128] output_s;
      mma.store mc, output_s;
      tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
    }
  }
}

__co__ void matmul_f16_unaligned_k(global f16 [M, K] lhs, global f16 [N, K] rhs,
                                    global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f16 [64, 64] lhs_load_s;
    shared f16 [128, 64] rhs_load_s;
    parallel p by 1 : group-4 {
      mc = mma.fill.f16 0.0f;
      foreach {iv_k} in [cdiv(K, 64)] {
        dma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => lhs_load_s;
        dma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        foreach {iv_warp} in [cdiv(64, 16)] {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
      shared f16 [64, 128] output_s;
      mma.store mc, output_s;
      tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
    }
  }
}

__co__ void matmul_f16_mwg_sm90(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 128), cdiv(N, 64)] : block {
    shared f16 [128, 64] lhs_load_s;
    shared f16 [64, 64] rhs_load_s;
    shared f16 [128, 64] output_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs.subspan(128, 64).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      parallel p1 by 2 : group-4 {
        foreach {iv_warp} in [cdiv(64, 16)] {
          ma = mma.desc lhs_load_s.chunkat(p1, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
        if (iv_k == cdiv(K, 64) - 1) mma.store mc, output_s.chunkat(p1, _);
      }
    }
    tma.copy output_s => output.subspan(128, 64).at(block_m, block_n);
  }
}

__co__ void matmul_f16_mwg_impl_1(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 128), cdiv(N, 64)] : block {
    shared f16 [128, 64] lhs_load_s;
    shared f16 [64, 64] rhs_load_s;
    shared f16 [128, 64] output_s;
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs.subspan(128, 64).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      parallel p1 by 2 : group-4 {
        foreach {iv_warp} in [cdiv(64, 16)] {
          ma = mma.desc lhs_load_s.subspan(64, 64).at(p1, 0).chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }
    parallel p1 by 2 : group-4 {
      mma.store mc, output_s.subspan(64, 64).at(p1, 0);
    }
    tma.copy output_s => output.subspan(128, 64).at(block_m, block_n);
  }
}

__co__ void matmul_f16_mwg_impl_3(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 128), cdiv(N, 64)] : block {
    shared f16 [128, 64] lhs_load_s;
    shared f16 [64, 64] rhs_load_s;
    shared f16 [128, 64] output_s;
    parallel p1 by 2 : group-4 {
      mc = mma.fill.f32 0.0f;
      foreach {iv_k} in [cdiv(K, 64)] {
        dma.copy.swiz<128> lhs.subspan(128, 64).at(block_m, iv_k) => lhs_load_s;
        dma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
        foreach {iv_warp} in [cdiv(64, 16)] {
          ma = mma.desc lhs_load_s.subspan(64, 64).at(p1, 0).chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
      mma.store mc, output_s.subspan(64, 64).at(p1, 0);
    }
    tma.copy output_s => output.subspan(128, 64).at(block_m, block_n);
  }
}

__co__ void matmul_trans_sm90(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [N, M] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f16 [64, 64] lhs_load_s;
    shared f16 [128, 64] rhs_load_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs.subspan(64, 64).at(block_m, iv_k) => lhs_load_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;
      foreach {iv_warp} in [cdiv(64, 16)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_load_s.chunkat(_, iv_warp);
          mb = mma.desc rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }
    shared f16 [128, 64] output_s;
    mma.store.transp mc, output_s;
    tma.copy output_s => output.subspan(128, 64).at(block_n, block_m);
  }
}

__co__ void matmul_auto(global f16 [M, K] lhs, global f16 [N, K] rhs,
                        global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f16 [64, 64] lhs_s;
    shared f16 [128, 64] rhs_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs
        .subspan(64, 64).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<128> rhs
        .subspan(128, 64).at(block_n, iv_k) => rhs_s;
      foreach {iv_wk} in [cdiv(64, 16)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_s.chunkat(_, iv_wk);
          mb = mma.desc rhs_s.chunkat(_, iv_wk);
          mma.row.row mc, ma, mb;
        }
      }
    }
    mma.store mc, output.subspan(64, 128).at(block_m, block_n);
  }
}

__co__ void matmul_explicit(global f16 [M, K] lhs, global f16 [N, K] rhs,
                            global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared f16 [64, 64] lhs_s;
    shared f16 [128, 64] rhs_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, 64)] {
      tma.copy.swiz<128> lhs
        .subspan(64, 64).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<128> rhs
        .subspan(128, 64).at(block_n, iv_k) => rhs_s;
      foreach {iv_wk} in [cdiv(64, 16)] {
        parallel p by 1 : group-4 {
          ma = mma.desc lhs_s.chunkat(_, iv_wk);
          mb = mma.desc rhs_s.chunkat(_, iv_wk);
          mma.row.row mc, ma, mb;
        }
      }
    }
    row_guard = M - block_m * 64;
    col_guard = N - block_n * 128;
    mma.store.mask mc,
      output.subspan(64, 128).at(block_m, block_n),
      row_guard, col_guard;
  }
}

__co__ void matmul_f16_ws_1p1c(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {

  parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
    shared event full[4], empty[4];
    shared f16 [64, 64] lhs_load_s[4];
    shared f16 [128, 64] rhs_load_s[4];
    shared f16 [64, 128] output_s;

    parallel p1 by 2 : group-4, t by 128 : thread {
      inthreads.async (p1 == 0) {
        foreach {iv_k} in [cdiv(K, 64)] {
          stage = iv_k % 4;
          wait empty[stage];
          tma.copy.async<full[stage]>.swiz<128> lhs.subspan(64, 64).at(block_m, iv_k) => lhs_load_s[stage];
          tma.copy.async<full[stage]>.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s[stage];
          trigger full[stage];
        }
      }
      inthreads.async (p1 == 1) {
        mc = mma.fill.f16 0.0f;
        foreach {s} in [4] {
          trigger empty[s];
        }
        foreach {iv_k} in [cdiv(K, 64)] {
          stage = iv_k % 4;
          wait full[stage];
          foreach {iv_warp} in [cdiv(64, 16)] {
            ma = mma.desc lhs_load_s[stage].chunkat(_, iv_warp);
            mb = mma.desc rhs_load_s[stage].chunkat(_, iv_warp);
            mma.row.row mc, ma, mb;
          }
          trigger empty[stage];
        }
        mma.store mc, output_s;
        tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
      }
    }
  }
}

__co__ void matmul_f16_ws_1p3c(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {

  parallel {block_m, block_n} by [cdiv(M, 192), cdiv(N, 128)] : block {
    shared event full[2], empty[2];
    shared f16 [192, 64] lhs_load_s[2];
    shared f16 [128, 64] rhs_load_s[2];
    shared f16 [192, 128] output_s;

    parallel p1 by 4 : group-4, t by 128 : thread {
      inthreads.async (p1 == 0) {
        foreach {iv_k} in [cdiv(K, 64)] {
          stage = iv_k % 2;
          wait empty[stage];
          tma.copy.async<full[stage]>.swiz<128> lhs.subspan(192, 64).at(block_m, iv_k) => lhs_load_s[stage];
          tma.copy.async<full[stage]>.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s[stage];
          trigger full[stage];
        }
      }
      inthreads.async (p1 > 0) {
        mc = mma.fill.f16 0.0f;
        foreach {s} in [2] {
          trigger empty[s];
        }
        foreach {iv_k} in [cdiv(K, 64)] {
          stage = iv_k % 2;
          wait full[stage];
          foreach {iv_warp} in [cdiv(64, 16)] {
            ma = mma.desc lhs_load_s[stage].subspan(64, 64).at(p1 - 1, 0).chunkat(_, iv_warp);
            mb = mma.desc rhs_load_s[stage].chunkat(_, iv_warp);
            mma.row.row mc, ma, mb;
          }
          trigger empty[stage];
        }
        mma.store mc, output_s.subspan(64, 128).at(p1 - 1, 0);
      }
    }

    tma.copy output_s => output.subspan(192, 128).at(block_m, block_n);
  }
}

__co__ void matmul_e4m3_ws_tbc(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs, global f16 [M, N] output) {
  parallel {cm} by [2] : cluster {
    parallel {block_m, block_n} by [cdiv(M, 64), cdiv(N, 128)] : block {
      shared event full[2], empty[2];
      shared f8_e4m3 [64, 128] lhs_load_s[2];
      shared f8_e4m3 [128, 128] rhs_load_s[2];
      shared f16 [64, 128] output_s;

      parallel p1 by 2 : group-4 {
        inthreads.async (p1 == 0) {
          foreach {iv_k} in [cdiv(K, 128)] {
            stage = iv_k % 2;
            wait empty[stage];
            tma.copy.async<full[stage]>.swiz<128> lhs.subspan(64, 128).at(block_m, iv_k) => lhs_load_s[stage];
            tma.copy.async<full[stage]>.multicast.swiz<128> rhs.subspan(128, 128).at(block_n, iv_k) => rhs_load_s[stage];
            trigger full[stage];
          }
        }
        inthreads.async (p1 == 1) {
          mc = mma.fill.f16 0.0f;
          foreach {s} in [2] {
            trigger.cluster empty[s];
          }
          foreach {iv_k} in [cdiv(K, 128)] {
            stage = iv_k % 2;
            wait full[stage];
            foreach {iv_warp} in [cdiv(128, 32)] {
              ma = mma.desc lhs_load_s[stage].chunkat(_, iv_warp);
              mb = mma.desc rhs_load_s[stage].chunkat(_, iv_warp);
              mma.row.row mc, ma, mb;
            }
            trigger.cluster empty[stage];
          }
          mma.store mc, output_s;
          tma.copy output_s => output.subspan(64, 128).at(block_m, block_n);
        }
      }
    }
  }
}


#pragma pop_macro("K")
#pragma pop_macro("N")
#pragma pop_macro("M")

static void instantiate_migrated_wgmma_ss() {
  size_t m = 256, n = 256, k = 256;
  half *f16_lhs = nullptr, *f16_rhs = nullptr, *f16_out = nullptr;
  __nv_fp8_e4m3 *fp8_lhs = nullptr, *fp8_rhs = nullptr;
  float *scale_lhs = nullptr, *scale_rhs = nullptr;

  auto fl = choreo::make_spanview<choreo::f16, 2>(f16_lhs, {m, k});
  auto fr = choreo::make_spanview<choreo::f16, 2>(f16_rhs, {n, k});
  auto fo = choreo::make_spanview<choreo::f16, 2>(f16_out, {m, n});
  auto el = choreo::make_spanview<choreo::f8_e4m3, 2>(fp8_lhs, {m, k});
  auto er = choreo::make_spanview<choreo::f8_e4m3, 2>(fp8_rhs, {n, k});
  auto sl = choreo::make_spanview<choreo::f32, 2>(scale_lhs, {m, k / 128});
  auto sr = choreo::make_spanview<choreo::f32, 2>(scale_rhs,
                                                  {n / 48, k / 128});

  matmul_e4m3_sm90(el, er, fo);
  matmul_e4m3_mwg_sm90(el, er, fo);
  matmul_e4m3_mwg_tbc_sm90(el, er, fo);
  blockscale_gemm_e4m3_n48(el, sl, er, sr, fo);
  matmul_f16_sm90(fl, fr, fo);
  matmul_f16_sm90_n96(fl, fr, fo);
  matmul_f16_sm90_tbc(fl, fr, fo);
  matmul_f16_unaligned_k(fl, fr, fo);
  matmul_f16_mwg_sm90(fl, fr, fo);
  matmul_f16_mwg_impl_1(fl, fr, fo);
  matmul_f16_mwg_impl_3(fl, fr, fo);
  matmul_trans_sm90(fl, fr, fo);
  matmul_auto(fl, fr, fo);
  matmul_explicit(fl, fr, fo);
  matmul_f16_ws_1p1c(fl, fr, fo);
  matmul_f16_ws_1p3c(fl, fr, fo);
  matmul_e4m3_ws_tbc(el, er, fo);
}

int main() {
  wgmma_dynamic_main(0, nullptr);
  wgmma_kmn_main();
  wgmma_fp8_main();
  std::cout << "All WGMMA SS Tests Passed\n";
}

