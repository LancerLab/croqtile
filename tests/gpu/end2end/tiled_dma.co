// ===== Category 6: dma.pad with tiled copy =====

// foo22: S2G pad, static shape, power-of-2 aligned (tiled VEC)
__co__ auto foo22(s32 [32, 64] input) {
  s32[32+2+2, 64+4+4] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [32, 64] buf;
      dma.copy input.subspan(32, 64) => buf;
      dma.pad<{2, 4}, {2, 4}, {0, 0}, 99> buf => output;
    }

  return output;
}

// foo23: G2S async pad, static shape (tiled CP_ASYNC)
__co__ auto foo23(s32 [32, 64] input) {
  s32[32+2+2, 64+4+4] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      f = dma.pad<{2, 4}, {2, 4}, {0, 0}, 99>.async input.subspan(32, 64) => shared;
      wait f;
      dma.copy f.data => output;
    }

  return output;
}

// foo24: S2G pad, non-aligned shape with predication
// Note: shared buffer is [32, 60] (ceiled from [30, 60]) to provide
// enough space for the tiled copy box which pads M for thread divisibility.
__co__ auto foo24(s32 [30, 60] input) {
  s32[30+2+3, 60+1+2] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [32, 60] buf;
      dma.copy input.subspan(30, 60) => buf.subspan(32, 60);
      dma.pad<{2, 1}, {3, 2}, {0, 0}, -1> buf.subspan(30, 60) => output;
    }

  return output;
}

void Run22() {
  auto input = choreo::make_spandata<choreo::s32>(32, 64);
  FillS32(input);

  auto output = foo22(input.view());
  for (size_t i = 0; i < 36; ++i)
    for (size_t j = 0; j < 72; ++j) {
      if (i >= 2 && i < 34 && j >= 4 && j < 68)
        choreo::choreo_assert(output[i][j] == input[i - 2][j - 4],
                              "foo22 data mismatch");
      else
        choreo::choreo_assert(output[i][j] == 99, "foo22 pad mismatch");
    }

  std::cout << "Test Foo22 Passed\n" << std::endl;
}

