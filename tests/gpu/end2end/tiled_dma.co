// REQUIRES: TARGET-SM_90A
// RUN: choreo -t cute -gs -arch=sm_90a %s | bash -s -- --execute | FileCheck --match-full-lines %s
// RUN-COCR: cocc -t cute -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
// RUN-COCR: cocc -t gpu -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s

#include "choreo.h"

__co__ auto foo1(s32 [32, 32] input) {
  s32[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(32, 32) => shared;
      dma.copy tile => output;
    }

  return output;
}

__co__ auto foo2(f16 [31, 32] input) {
  f16[32, 32] output {0.0f};

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared f16 [32, 32] buf;
      dma.copy input.subspan(31, 32) => buf.subspan(32, 32);
      dma.copy buf => output;
    }

  return output;
}

__co__ auto foo3(f16 [32, 1024] input) {
  f16[7, 32] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(7, 32) => shared;
      dma.copy tile => output;
    }

  return output;
}

__co__ auto foo4(s32 [32, 64] input) {
  s32[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [32, 64] buf;
      fut = dma.copy.async input.subspan(32, 64) => buf.subspan(32, 64);
      wait fut;
      dma.copy buf.subspan(32, 64) => output;
    }

  return output;
}

__co__ auto foo5(f16 [31, 64] input) {
  f16[32, 64] output {0.0f};

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared f16 [32, 64] buf;
      dma.copy input.subspan(31, 64) => buf.subspan(32, 64);
      dma.copy buf => output;
    }

  return output;
}

__co__ auto foo6(f32 [128, 128] input) {
  f32[32, 32] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared f32 [32, 32] buf;
      dma.copy input.subspan(32, 32).at(1, 2) => buf;
      dma.copy buf => output;
    }

  return output;
}

__co__ auto foo7(s32 [64, 32] input) {
  s32[input.span] output;

  parallel p by 1 : block {
    parallel g by 1 : group-4 {
      shared s32 [64, 32] buf;
      dma.copy input.subspan(64, 32) => buf;
      dma.copy buf => output;
    }
  }

  return output;
}

// ================================================================
// Category A: Copy Atom -- VEC atom for G2S
// ================================================================

// foo8: 16 threads -> cp.async disabled (non-warp-multiple), uses VEC_128B atom
//       Also exercises non-power-of-2 inner dimension (N=48)
__co__ auto foo8(s32 [16, 48] input) {
  s32[input.span] output;

  parallel p by 1 : block
    parallel q by 16 : thread {
      tile = dma.copy input.subspan(16, 48) => shared;
      dma.copy tile => output;
    }

  return output;
}

// ================================================================
// Category B: Element Type -- s8 (8-bit integer)
// ================================================================

// foo9: s8 with 128-bit vectorization -- vector_factor=16, val_layout=(1,16)
__co__ auto foo9(s8 [32, 128] input) {
  s8[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(32, 128) => shared;
      dma.copy tile => output;
    }

  return output;
}

// ================================================================
// Category C: Predication Variants
// ================================================================

// foo10: source-extent predication with s32 -- from (13,32) padded into (16,32) shared
//        Tests predicated tiled copy with integer type (distinct from f16 in foo2/foo5)
__co__ auto foo10(s32 [13, 32] input) {
  s32[13, 32] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [16, 32] buf;
      dma.copy input.subspan(13, 32) => buf.subspan(16, 32);
      dma.copy buf.subspan(13, 32) => output;
    }

  return output;
}

// foo11: async G2S + source-extent predication -- from (13,64) into (16,64) shared
//        Tests CP_ASYNC atom combined with predicated tail handling
__co__ auto foo11(s32 [13, 64] input) {
  s32[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [16, 64] buf;
      fut = dma.copy.async input.subspan(13, 64) => buf.subspan(16, 64);
      wait fut;
      dma.copy buf.subspan(13, 64) => output;
    }

  return output;
}

// ================================================================
// Category D: Thread Count Variants
// ================================================================

// foo12: 64 participating threads -- different thread decomposition than 32
__co__ auto foo12(f16 [64, 64] input) {
  f16[input.span] output;

  parallel p by 1 : block
    parallel q by 64 : thread {
      tile = dma.copy input.subspan(64, 64) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo13: 256 participating threads -- large (16,16) thread layout
__co__ auto foo13(f16 [128, 128] input) {
  f16[input.span] output;

  parallel p by 1 : block
    parallel q by 256 : thread {
      tile = dma.copy input.subspan(128, 128) => shared;
      dma.copy tile => output;
    }

  return output;
}

// ================================================================
// Category E: Tile Shape Variants
// ================================================================

// foo14: wide tile (M << N) -- thread layout where thr_n >> thr_m
__co__ auto foo14(f16 [4, 128] input) {
  f16[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(4, 128) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo15: tall tile (M >> N) -- thread layout where thr_m >> thr_n
__co__ auto foo15(s32 [128, 16] input) {
  s32[input.span] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(128, 16) => shared;
      dma.copy tile => output;
    }

  return output;
}

// ================================================================
// Category F: Dynamic Strides (runtime dimensions)
//   When the outer dimension is dynamic, the compiler cannot statically
//   determine row-stride alignment.  detect_align_bits sees a non-integer
//   stride and returns 1, forcing vector_factor=1.
//   - s8  (8-bit)  -> param.align_bits=8  -> DEFAULT -> UniversalCopy atom
//   - f16 (16-bit) -> param.align_bits=16 -> VEC_16B (degraded vectorization)
//   - s32 (32-bit) -> param.align_bits=32 -> VEC_32B (degraded vectorization)
// ================================================================

// foo16: s8 dynamic stride -> UniversalCopy atom for G2S tiled copy
//        The only element width where dynamic stride triggers DEFAULT atom
__co__ auto foo16(s8 [M, N] input) {
  s8[32, 64] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(32, 64) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo17: s32 dynamic stride -> VEC_32B atom (degraded from VEC_128B)
//        Verifies tiled copy still functions with reduced vectorization
__co__ auto foo17(s32 [M, N] input) {
  s32[16, 32] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(16, 32) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo18: s8 dynamic stride + zfill predication -> UniversalCopy + pred
//        from (13, 64) into (16, 64) shared, source extent < tile -> predication
__co__ auto foo18(s8 [M, N] input) {
  s8[13, 64] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s8 [16, 64] buf;
      dma.copy input.subspan(13, 64) => buf.subspan(16, 64);
      dma.copy buf.subspan(13, 64) => output;
    }

  return output;
}

// foo19: s32 dynamic stride + subspan.step.at -> VEC_32B + offset computation
//        Exercises the GenOffset fix for SubSpan with explicit steps and
//        dynamic input strides; selects tile at (1, 2)
__co__ auto foo19(s32 [M, N] input) {
  s32[32, 32] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(32, 32).step(32, 32).at(1, 2) => shared;
      dma.copy tile => output;
    }

  return output;
}

// ================================================================
// Category G: Transpose DMA (dma.transp)
// ================================================================

// foo20: dma.transp<1,0> with static shapes -- basic G2S transpose
//        Source [64, 128] transposed into [128, 64] shared
__co__ auto foo20(s32 [64, 128] input) {
  s32 [128, 64] output;

  parallel p by 1 : block, by 1 : group {
    tile = dma.transp<1, 0> input => shared;
    dma.copy tile => output;
  }

  return output;
}

// foo21: dma.transp<1,0> with dynamic stride -- transpose + UniversalCopy/degraded atom
//        Tests transpose combined with dynamic-stride alignment fallback
__co__ auto foo21(s32 [M, N] input) {
  s32 [32, 16] output;

  parallel p by 1 : block, by 1 : group {
    tile = dma.transp<1, 0> input.subspan(16, 32) => shared;
    dma.copy tile => output;
  }

  return output;
}

// ================================================================
// Category H: 1D Tensor DMA (rank-1 reshaped to [1, N])
// ================================================================

// foo25: basic 1D s32 copy -- 128 elements, 32 threads, CP_ASYNC_128B
__co__ auto foo25(s32 [128] input) {
  s32[128] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(128) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo26: 1D f16 copy -- 256 elements, 32 threads
__co__ auto foo26(f16 [256] input) {
  f16[256] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(256) => shared;
      dma.copy tile => output;
    }

  return output;
}

// foo27: 1D s32 async copy -- tests cp.async with 1D
__co__ auto foo27(s32 [64] input) {
  s32[64] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      shared s32 [64] buf;
      fut = dma.copy.async input.subspan(64) => buf.subspan(64);
      wait fut;
      dma.copy buf.subspan(64) => output;
    }

  return output;
}

// foo28: 1D s8 copy -- small element type, 128 elements, 32 threads
__co__ auto foo28(s8 [512] input) {
  s8[512] output;

  parallel p by 1 : block
    parallel q by 32 : thread {
      tile = dma.copy input.subspan(512) => shared;
      dma.copy tile => output;
    }

  return output;
}

void FillS32(choreo::spanned_data<choreo::s32, 2>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    for (size_t j = 0; j < data.shape()[1]; ++j)
      data[i][j] = static_cast<choreo::s32>((i * 17 + j * 5) % 41 - 20);
}

void FillF16(choreo::spanned_data<choreo::f16, 2>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    for (size_t j = 0; j < data.shape()[1]; ++j)
      data[i][j] = choreo::f32_to_f16(static_cast<float>(((i * 7) + j) % 19 - 9));
}

void FillF32(choreo::spanned_data<choreo::f32, 2>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    for (size_t j = 0; j < data.shape()[1]; ++j)
      data[i][j] = static_cast<choreo::f32>((i * 13 + j * 3) % 37 - 18);
}

void FillS8(choreo::spanned_data<choreo::s8, 2>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    for (size_t j = 0; j < data.shape()[1]; ++j)
      data[i][j] = static_cast<choreo::s8>((i * 7 + j * 3) % 127 - 63);
}

void FillS32_1D(choreo::spanned_data<choreo::s32, 1>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    data[i] = static_cast<choreo::s32>((i * 17 + 5) % 41 - 20);
}

void FillF16_1D(choreo::spanned_data<choreo::f16, 1>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    data[i] = choreo::f32_to_f16(static_cast<float>((i * 7 + 3) % 19 - 9));
}

void FillS8_1D(choreo::spanned_data<choreo::s8, 1>& data) {
  for (size_t i = 0; i < data.shape()[0]; ++i)
    data[i] = static_cast<choreo::s8>((i * 7 + 3) % 127 - 63);
}

void Run1() {
  auto input = choreo::make_spandata<choreo::s32>(32, 32);
  FillS32(input);

  auto output = foo1(input.view());
  for (size_t i = 0; i < 32; ++i)
    for (size_t j = 0; j < 32; ++j)
      choreo::choreo_assert(output[i][j] == input[i][j], "foo1 mismatch");

  std::cout << "Test Foo1 Passed\n" << std::endl;
}

void Run2() {
  auto input = choreo::make_spandata<choreo::f16>(31, 32);
  FillF16(input);

  auto output = foo2(input.view());
  for (size_t i = 0; i < 31; ++i)
    for (size_t j = 0; j < 32; ++j)
      choreo::choreo_assert(
          choreo::f16_to_f32(output[i][j]) == choreo::f16_to_f32(input[i][j]),
          "foo2 copied region mismatch");
  for (size_t j = 0; j < 32; ++j)
    choreo::choreo_assert(choreo::f16_to_f32(output[31][j]) == 0.0f,
                          "foo2 zfill row mismatch");

  std::cout << "Test Foo2 Passed\n" << std::endl;
}

