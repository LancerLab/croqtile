// REQUIRES: TARGET-SM_90
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && CUDA_VISIBLE_DEVICES=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#include <cstring>
#include <cstdlib>

// SM86 mma.sync tile: m16n16k16
#define MATMUL_MMA_M 16
#define MATMUL_MMA_N 16
#define MATMUL_MMA_K 16

// Block tile defaults
#define MATMUL_TILE_M 16
#define MATMUL_TILE_N 16
#define MATMUL_TILE_K 16

// Number of SMs on target GPU (RTX 3090 = 82, A40 = 84)
#define NUM_SMS 82

#if MATMUL_TILE_M % MATMUL_MMA_M != 0
#error "MATMUL_TILE_M must be divisible by MATMUL_MMA_M"
#endif

#if MATMUL_TILE_N % MATMUL_MMA_N != 0
#error "MATMUL_TILE_N must be divisible by MATMUL_MMA_N"
#endif

#if MATMUL_TILE_K % MATMUL_MMA_K != 0
#error "MATMUL_TILE_K must be divisible by MATMUL_MMA_K"
#endif

#if (MATMUL_TILE_M / MATMUL_MMA_M) * (MATMUL_TILE_N / MATMUL_MMA_N) > 8
#error "Too many warps: (TILE_M/MMA_M)*(TILE_N/MMA_N) must be <= 8 (255 regs/thread)"
#endif

#define MATMUL_DEFAULT_M 256
#define MATMUL_DEFAULT_N 256
#define MATMUL_DEFAULT_K 256

// --- Optimization: Swizzle tile scheduling (persistent) ---
// Uses a host-computed diagonal swizzle pattern for tile ordering.
// The idea (from kebab V6 tile scheduler concept): tiles are assigned
// along diagonals of the (tiles_m x tiles_n) grid, so consecutive tiles
// processed by an SM share partial rows (A) or columns (B), providing
// balanced L2 cache reuse for both A and B matrices.
//
// Swizzle pattern: walk diagonals d=0..tiles_m+tiles_n-2,
//   for each diagonal d: (i, d-i) where max(0,d-tiles_n+1) <= i <= min(d, tiles_m-1)
//   This gives tiles that share A-rows and B-columns in alternation.
__co__ void matmul(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output,
                   global s32 [T] schedule_m, global s32 [T] schedule_n) {

  int total_tiles = cdiv(M, MATMUL_TILE_M) * cdiv(N, MATMUL_TILE_N);

  parallel block_id by NUM_SMS : block {
    shared f16 [MATMUL_TILE_M, MATMUL_TILE_N] output_s;

    foreach {tile_iter} in [cdiv(total_tiles, NUM_SMS)] {
      tile_id = tile_iter # block_id;
      if (tile_id < total_tiles) {
        int block_m = schedule_m.at(tile_id);
        int block_n = schedule_n.at(tile_id);

        parallel {warp_m, warp_n} by [cdiv(MATMUL_TILE_M, MATMUL_MMA_M), cdiv(MATMUL_TILE_N, MATMUL_MMA_N)] : group {
          mc = mma.fill 0.0;
          foreach {iv_k} in [cdiv(K, MATMUL_TILE_K)] {
            lhs_load_s = dma.copy.async lhs.subspan(MATMUL_TILE_M, MATMUL_TILE_K).at(block_m, iv_k) => shared;
            rhs_load_s = dma.copy.async rhs.subspan(MATMUL_TILE_N, MATMUL_TILE_K).at(block_n, iv_k) => shared;
            wait lhs_load_s, rhs_load_s;

            foreach {iv_warp_k} in [cdiv(MATMUL_TILE_K, MATMUL_MMA_K)] {
              ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
              mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
              mma.row.row mc, ma, mb;
            }
          }
          mma.store mc, output_s.chunkat(warp_m, warp_n);
        }
        dma.copy output_s => output.subspan(MATMUL_TILE_M, MATMUL_TILE_N).at(block_m, block_n);
      }
    }
  }
}

// ===================================================================
// Diagonal swizzle schedule builder (host-side)
// ===================================================================
// Walk anti-diagonals of the tile grid: tiles on the same diagonal
// share neighbors in both row and column directions, leading to
// balanced L2 locality for both A and B matrices.
static int build_swizzle_schedule(int tiles_m, int tiles_n,
                                  int* schedule_m, int* schedule_n) {
  int count = 0;
  int num_diags = tiles_m + tiles_n - 1;
  for (int d = 0; d < num_diags; ++d) {
    int i_start = (d < tiles_n) ? 0 : (d - tiles_n + 1);
    int i_end   = (d < tiles_m) ? d : (tiles_m - 1);
    for (int i = i_start; i <= i_end; ++i) {
      int j = d - i;
      schedule_m[count] = i;
      schedule_n[count] = j;
      ++count;
    }
  }
  return count;
}

int main(int argc, char** argv) {
  bool skip_verify = false;
  auto is_skip_verify_arg = [](const char* s) {
    const char* t = "--skip-verify";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i) {
    if (is_skip_verify_arg(argv[i])) {
      skip_verify = true;
    }
  }

  const char* skip_verify_env = std::getenv("CHOREO_SKIP_VERIFY");
  if (skip_verify_env && skip_verify_env[0] == '1' && skip_verify_env[1] == '\0') {
    skip_verify = true;
  }

  size_t M = MATMUL_DEFAULT_M;
  size_t N = MATMUL_DEFAULT_N;
  size_t K = MATMUL_DEFAULT_K;

  // -- Build swizzle schedule --
  int tiles_m = (M + MATMUL_TILE_M - 1) / MATMUL_TILE_M;
  int tiles_n = (N + MATMUL_TILE_N - 1) / MATMUL_TILE_N;
  int total_tiles = tiles_m * tiles_n;

  int* sched_m_h = (int*)std::malloc(total_tiles * sizeof(int));
  int* sched_n_h = (int*)std::malloc(total_tiles * sizeof(int));
  int count = build_swizzle_schedule(tiles_m, tiles_n, sched_m_h, sched_n_h);
  if (count != total_tiles) {
    std::cerr << "Swizzle schedule mismatch: expected " << total_tiles
              << " tiles, got " << count << "\n";
    return 1;
  }

  int *sched_m_d = nullptr, *sched_n_d = nullptr;
  choreo::abend_true(cudaMalloc(&sched_m_d, total_tiles * sizeof(int)));
  choreo::abend_true(cudaMalloc(&sched_n_d, total_tiles * sizeof(int)));
  choreo::abend_true(cudaMemcpy(sched_m_d, sched_m_h, total_tiles * sizeof(int), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(sched_n_d, sched_n_h, total_tiles * sizeof(int), cudaMemcpyHostToDevice));
  std::free(sched_m_h);
  std::free(sched_n_h);

  auto sched_m_view = choreo::make_spanview<choreo::s32, 1>(sched_m_d, {(size_t)total_tiles});
  auto sched_n_view = choreo::make_spanview<choreo::s32, 1>(sched_n_d, {(size_t)total_tiles});

  // -- Allocate matmul data --
  auto lhs_h = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs_h = choreo::make_spandata<choreo::f16>(N, K);
  auto res_h = choreo::make_spandata<choreo::f16>(M, N);
  lhs_h.fill_random(0, 2);
  rhs_h.fill_random(0, 2);
  res_h.fill(0.0f);

  half *a_d = nullptr, *b_d = nullptr, *c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, M * K * sizeof(half)));
  choreo::abend_true(cudaMalloc(&b_d, N * K * sizeof(half)));
  choreo::abend_true(cudaMalloc(&c_d, M * N * sizeof(half)));

  choreo::abend_true(cudaMemcpy(a_d, lhs_h.data(), M * K * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs_h.data(), N * K * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(c_d, res_h.data(), M * N * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaDeviceSynchronize());

  auto lhs_d = choreo::make_spanview<choreo::f16, 2>(a_d, {M, K});
  auto rhs_d = choreo::make_spanview<choreo::f16, 2>(b_d, {N, K});
  auto res_d = choreo::make_spanview<choreo::f16, 2>(c_d, {M, N});

  matmul(lhs_d, rhs_d, res_d, sched_m_view, sched_n_view);

  choreo::abend_true(cudaMemcpy(res_h.data(), c_d, M * N * sizeof(half), cudaMemcpyDeviceToHost));
  choreo::abend_true(cudaDeviceSynchronize());

  if (skip_verify) {
    std::cout << "Test Passed (verify skipped)\n" << std::endl;
    return 0;
  }

  auto lhs_view = lhs_h.view();
  auto rhs_view = rhs_h.view();
  auto res_view = res_h.view();

  float tolerance = 0.05f;
  auto rel_error = [](float ref, float got) {
    float abs_ref = std::abs(ref);
    float denom = abs_ref > 1e-6f ? abs_ref : 1.0f;
    return std::abs(ref - got) / denom;
  };
  for (size_t i = 0; i < M; ++i) {
    for (size_t j = 0; j < N; ++j) {
      float ref = 0.0f;
      for (size_t k = 0; k < lhs_view.shape()[1]; ++k)
        ref += __half2float(lhs_view[i][k] * rhs_view[j][k]);
      float got = __half2float(res_view[i][j]);
      auto delta = rel_error(ref, got);
      if (delta >= tolerance) {
        std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << got << ", delta: " << delta * 100 << "%\n";
      }
      choreo::choreo_assert((delta < tolerance), "values are not equal.");
    }
  }

  std::cout << "Test Passed\n" << std::endl;

  cudaFree(sched_m_d);
  cudaFree(sched_n_d);
}

// CHECK: Test Passed
