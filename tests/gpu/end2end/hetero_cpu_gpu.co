// REQUIRES: TARGET-GPU
// RUN: choreo -t hetero -gs %s | bash -s -- --execute
// RUN-COCR: cocc -t cute -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s
// RUN-COCR: cocc -t gpu -gs %s | bash -s -- --execute | FileCheck --match-full-lines %s

#include "choreo.h"
#include <cmath>

__co__ void hetero_add(f32 [1024] A, f32 [1024] &B) {
  // CPU: A[i] += 1.0
  parallel.async by 1 : device(cpu) {
    foreach i in [1024] {
      A.at(i) = A.at(i) + 1.0;
    }
  }

  // GPU: B[i] += 2.0 via block/thread parallel
  parallel.async by 1 : device(gpu) {
    parallel p by 1 : block {
      parallel q by 1024 : thread
        B.at(q) = B.at(q) + 2.0;
    }
  }

  sync.global;
}

int main() {
  choreo::f32 a_buf[1024], b_buf[1024];
  auto A = choreo::make_spanview<1, choreo::f32>(a_buf, {1024});
  auto B = choreo::make_spanview<1, choreo::f32>(b_buf, {1024});

  for (int i = 0; i < 1024; ++i) {
    A[i] = static_cast<float>(i);
    B[i] = static_cast<float>(i * 2);
  }

  hetero_add(A, B);

  bool pass = true;
  for (int i = 0; i < 1024; ++i) {
    float expected_a = static_cast<float>(i) + 1.0f;
    if (std::fabs(A[i] - expected_a) > 1e-5f) {
      std::cerr << "CPU FAIL at " << i << ": expected " << expected_a
                << " got " << A[i] << "\n";
      pass = false;
      break;
    }
  }

  for (int i = 0; i < 1024; ++i) {
    float expected_b = static_cast<float>(i * 2) + 2.0f;
    if (std::fabs(B[i] - expected_b) > 1e-5f) {
      std::cerr << "GPU FAIL at " << i << ": expected " << expected_b
                << " got " << B[i] << "\n";
      pass = false;
      break;
    }
  }

  if (pass) std::cout << "Test Passed\n";
  else std::cerr << "Test Failed\n";
  return pass ? 0 : 1;
}
