// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define LEN 1024
#define N 64
#define M 32

// frag.copy: plain register-to-register copy
__co__ f32 [N] frag_copy_plain() {
  f32[N] out;
  parallel t by 128 : thread {
    fragment f32[LEN] a {0.0f};
    fragment f32[LEN] b {0.0f};
    frag.apply a, [](i) { return __to<f32>(i) * 5.0f; };
    frag.copy b, a;
    frag.store out, b;
  }
  return out;
}

// frag.copy with lambda: copy + transform
__co__ f32 [N] frag_copy_lambda() {
  f32[N] out;
  parallel t by 128 : thread {
    fragment f32[LEN] a {0.0f};
    fragment f32[LEN] b {0.0f};
    frag.apply a, [](i) { return __to<f32>(i) * 3.0f; };
    frag.copy b, a, [](i) { return a.at(i) + 100.0f; };
    frag.store out, b;
  }
  return out;
}

// frag.store: plain vec4 store from fragment to output memory
__co__ f32 [M, M] frag_store_plain() {
  f32[M, M] out;
  parallel t by 128 : thread {
    fragment f32[M, M] tile {0.0f};
    frag.apply tile, [](i, j) { return __to<f32>(i * M + j); };
    frag.store out, tile;
  }
  return out;
}

// frag.store with lambda: store with per-element transform
__co__ f32 [M, M] frag_store_lambda() {
  f32[M, M] out;
  parallel t by 128 : thread {
    fragment f32[M, M] tile {0.0f};
    frag.apply tile, [](i, j) { return __to<f32>(i * M + j); };
    frag.store out, tile, [](i, j) { return tile.at(i, j) * 2.0f; };
  }
  return out;
}

// frag.load: load from output memory (which was just stored) into another fragment
__co__ f32 [M, M] frag_load_roundtrip() {
  f32[M, M] tmp;
  f32[M, M] out;
  parallel t by 128 : thread {
    fragment f32[M, M] tile {0.0f};
    frag.apply tile, [](i, j) { return __to<f32>(i * M + j) * 3.0f; };
    frag.store tmp, tile;
    fragment f32[M, M] tile2;
    frag.load tile2, tmp;
    frag.store out, tile2;
  }
  return out;
}

int main() {
  {
    auto out = frag_copy_plain();
    for (size_t i = 0; i < N; ++i) {
      auto expect = (float)i * 5.0f;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "frag.copy plain mismatch.");
    }
    std::cout << "Test frag_copy_plain Passed" << std::endl;
  }

  {
    auto out = frag_copy_lambda();
    for (size_t i = 0; i < N; ++i) {
      auto expect = (float)i * 3.0f + 100.0f;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "frag.copy lambda mismatch.");
    }
    std::cout << "Test frag_copy_lambda Passed" << std::endl;
  }

  {
    auto out = frag_store_plain();
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < M; ++j) {
        auto expect = (float)(i * M + j);
        if (out[i][j] != expect)
          choreo::choreo_assert(out[i][j] == expect,
                                  "frag.store plain mismatch.");
      }
    std::cout << "Test frag_store_plain Passed" << std::endl;
  }

  {
    auto out = frag_store_lambda();
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < M; ++j) {
        auto expect = (float)(i * M + j) * 2.0f;
        if (out[i][j] != expect)
          choreo::choreo_assert(out[i][j] == expect,
                                  "frag.store lambda mismatch.");
      }
    std::cout << "Test frag_store_lambda Passed" << std::endl;
  }

  {
    auto out = frag_load_roundtrip();
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < M; ++j) {
        auto expect = (float)(i * M + j) * 3.0f;
        if (out[i][j] != expect)
          choreo::choreo_assert(out[i][j] == expect,
                                  "frag.load roundtrip mismatch.");
      }
    std::cout << "Test frag_load_roundtrip Passed" << std::endl;
  }
}

// CHECK: Test frag_copy_plain Passed
// CHECK: Test frag_copy_lambda Passed
// CHECK: Test frag_store_plain Passed
// CHECK: Test frag_store_lambda Passed
// CHECK: Test frag_load_roundtrip Passed
