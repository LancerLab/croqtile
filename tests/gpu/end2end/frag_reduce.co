// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define M 8
#define N 32

// frag.reduce_max: row-wise max of a 2D fragment
__co__ f32[M] test_reduce_max() {
  f32[M] out;
  parallel t by 128 : thread {
    fragment f32[M, N] src {0.0f};
    fragment f32[M] dst;
    // Fill: src[i][j] = i * N + j (values 0..255)
    frag.apply src, [](i, j) { return __to<f32>(i * N + j); };
    frag.reduce_max src, dst, 1;
    frag.store out, dst;
  }
  return out;
}

// frag.reduce_sum: row-wise sum of a 2D fragment
__co__ f32[M] test_reduce_sum() {
  f32[M] out;
  parallel t by 128 : thread {
    fragment f32[M, N] src {0.0f};
    fragment f32[M] dst;
    // Fill: src[i][j] = 1.0 for all elements -> row sum = N
    frag.apply src, [](i, j) { return 1.0f; };
    frag.reduce_sum src, dst, 1;
    frag.store out, dst;
  }
  return out;
}

// frag.reduce_max: constant rows should give that constant
__co__ f32[M] test_reduce_max_const() {
  f32[M] out;
  parallel t by 128 : thread {
    fragment f32[M, N] src {0.0f};
    fragment f32[M] dst;
    // Fill: src[i][j] = i + 1 (constant per row)
    frag.apply src, [](i, j) { return __to<f32>(i + 1); };
    frag.reduce_max src, dst, 1;
    frag.store out, dst;
  }
  return out;
}

int main() {
  {
    auto out = test_reduce_max();
    for (int i = 0; i < M; ++i) {
      float expect = (float)(i * N + (N - 1));
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "reduce_max mismatch");
    }
    std::cout << "Test reduce_max Passed" << std::endl;
  }

  {
    auto out = test_reduce_sum();
    for (int i = 0; i < M; ++i) {
      float expect = (float)N;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "reduce_sum mismatch");
    }
    std::cout << "Test reduce_sum Passed" << std::endl;
  }

  {
    auto out = test_reduce_max_const();
    for (int i = 0; i < M; ++i) {
      float expect = (float)(i + 1);
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "reduce_max_const mismatch");
    }
    std::cout << "Test reduce_max_const Passed" << std::endl;
  }
}

// CHECK: Test reduce_max Passed
// CHECK: Test reduce_sum Passed
// CHECK: Test reduce_max_const Passed
