// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define LEN 1024
#define N 64
#define M 32

// Equivalent of fragment_automap_1d, using frag.apply instead of automap.
__co__ f32 [N] frag_apply_1d() {
  f32[N] out;
  parallel t by 128 : thread {
    fragment f32[LEN] buf {0.0f};
    frag.apply buf, [](i) { return __to<f32>(i) * 2.0f; };
    frag.store out, buf;
  }
  return out;
}

// Equivalent of fragment_automap_2d, using frag.apply instead of automap.
__co__ f32 [M, M] frag_apply_2d() {
  f32[M, M] out;
  parallel t by 128 : thread {
    fragment f32[M, M] tile {0.0f};
    frag.apply tile, [](i, j) { return __to<f32>(i * M + j); };
    frag.store out, tile;
  }
  return out;
}

// Test frag.apply reading another fragment (a.at(i) in the body).
__co__ f32 [N] frag_apply_read_other() {
  f32[N] out;
  parallel t by 128 : thread {
    fragment f32[LEN] a {0.0f};
    fragment f32[LEN] b {0.0f};
    frag.apply a, [](i) { return __to<f32>(i) * 3.0f; };
    frag.apply b, [](i) { return a.at(i) + 10.0f; };
    frag.store out, b;
  }
  return out;
}

int main() {
  {
    auto out = frag_apply_1d();
    for (size_t i = 0; i < N; ++i) {
      auto expect = (float)i * 2.0f;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect, "frag.apply 1d mismatch.");
    }
    std::cout << "Test frag_apply_1d Passed" << std::endl;
  }

  {
    auto out = frag_apply_2d();
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < M; ++j) {
        auto expect = (float)(i * M + j);
        if (out[i][j] != expect)
          choreo::choreo_assert(out[i][j] == expect,
                                  "frag.apply 2d mismatch.");
      }
    std::cout << "Test frag_apply_2d Passed" << std::endl;
  }

  {
    auto out = frag_apply_read_other();
    for (size_t i = 0; i < N; ++i) {
      auto expect = (float)i * 3.0f + 10.0f;
      if (out[i] != expect)
        choreo::choreo_assert(out[i] == expect,
                                "frag.apply read_other mismatch.");
    }
    std::cout << "Test frag_apply_read_other Passed" << std::endl;
  }
}

// CHECK: Test frag_apply_1d Passed
// CHECK: Test frag_apply_2d Passed
// CHECK: Test frag_apply_read_other Passed
