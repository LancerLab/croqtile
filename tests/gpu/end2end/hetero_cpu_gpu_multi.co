// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t hetero %s -o %s.hetero.result && bash %s.hetero.result --execute && rm -f %s.hetero.result

#include "choreo.h"
#include <cmath>

__co__ void hetero_multi_phase(f32 [256] A, f32 [256] &B, f32 [256] &C) {
  // Phase 1: CPU initializes A, GPU initializes B concurrently
  parallel.async by 1 : device(cpu) {
    foreach i in [256] {
      A.at(i) = A.at(i) + 1.0;
    }
  }

  parallel.async by 1 : device(gpu) {
    parallel p by 1 : block {
      parallel q by 256 : thread
        B.at(q) = B.at(q) * 2.0;
    }
  }

  sync.global;

  // Phase 2: CPU computes C = A + B
  parallel.async by 1 : device(cpu) {
    foreach i in [256] {
      C.at(i) = A.at(i) + B.at(i);
    }
  }

  sync.global;
}

int main() {
  choreo::f32 a_buf[256], b_buf[256], c_buf[256];
  auto A = choreo::make_spanview<1, choreo::f32>(a_buf, {256});
  auto B = choreo::make_spanview<1, choreo::f32>(b_buf, {256});
  auto C = choreo::make_spanview<1, choreo::f32>(c_buf, {256});

  for (int i = 0; i < 256; ++i) {
    A[i] = static_cast<float>(i);
    B[i] = static_cast<float>(i);
    C[i] = 0.0f;
  }

  hetero_multi_phase(A, B, C);

  bool pass = true;
  for (int i = 0; i < 256; ++i) {
    float expected_a = static_cast<float>(i) + 1.0f;
    float expected_b = static_cast<float>(i) * 2.0f;
    float expected_c = expected_a + expected_b;

    if (std::fabs(A[i] - expected_a) > 1e-5f) {
      std::cerr << "Phase1 CPU FAIL at " << i << ": expected " << expected_a
                << " got " << A[i] << "\n";
      pass = false;
      break;
    }
    if (std::fabs(B[i] - expected_b) > 1e-5f) {
      std::cerr << "Phase1 GPU FAIL at " << i << ": expected " << expected_b
                << " got " << B[i] << "\n";
      pass = false;
      break;
    }
    if (std::fabs(C[i] - expected_c) > 1e-5f) {
      std::cerr << "Phase2 CPU FAIL at " << i << ": expected " << expected_c
                << " got " << C[i] << "\n";
      pass = false;
      break;
    }
  }

  if (pass) std::cout << "Test Passed\n";
  else std::cerr << "Test Failed\n";
  return pass ? 0 : 1;
}
