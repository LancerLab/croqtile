// REQUIRES: TARGET-SM_86+
// RUN: choreo -gs -t cute -arch=sm_86 %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// MMA instruction coverage

// --- mma_v1.co: 2x2 group, row.col ---
#define M_GROUP_RC 128
#define N_GROUP_RC 256
#define K_GROUP_RC 256

__co__ auto matmul_group_rc(f16 [M_GROUP_RC, K_GROUP_RC] lhs, f16 [K_GROUP_RC, N_GROUP_RC] rhs) {
  f16 [M_GROUP_RC, N_GROUP_RC] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [M_GROUP_RC / MMA_M / 2, N_GROUP_RC / MMA_N / 2] : block {
    mc = mma.fill 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K_GROUP_RC / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

// --- mma_v2.co: pipelined with double-buffer swap ---
#define M_PIPELINE 64
#define N_PIPELINE 32
#define K_PIPELINE 16

__co__ auto matmul_pipeline(f16 [M_PIPELINE, K_PIPELINE] lhs, f16 [K_PIPELINE, N_PIPELINE] rhs) {
  f16 [M_PIPELINE, N_PIPELINE] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [M_PIPELINE / MMA_M / 4, N_PIPELINE / MMA_N] : block {
    parallel {g0, g1} by [4, 1]: group {
      mc = mma.fill 0.0;
      with k in K_PIPELINE / MMA_K {
        fl0 = dma.copy.async lhs => shared;
        fr0 = dma.copy.async rhs => shared;
        fl1 = dma.any;
        fr1 = dma.any;
        foreach k(1:) {
          fl1 = dma.copy.async lhs => shared;
          fr1 = dma.copy.async rhs => shared;

          wait fl0, fr0;
          ma = mma.load fl0.chunkat(m#g0, k - 1);
          mb = mma.load fr0.chunkat(k - 1, n#g1);
          mma.row.col mc, ma, mb;

          swap(fl0, fl1);
          swap(fr0, fr1);
        }

        wait fl0, fr0;
        ma = mma.load fl0.chunkat(m#g0, k(-1));
        mb = mma.load fr0.chunkat(k(-1), n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

// --- mma_fusion_scalar.co: row.col with scalar bias fusion ---
#define M_FUSION 128
#define N_FUSION 256
#define K_FUSION 256

__co__ auto matmul_fusion_scalar(f16 [M_FUSION, K_FUSION] lhs, f16 [K_FUSION, N_FUSION] rhs, f16 bias) {
  f16 [M_FUSION, N_FUSION] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [M_FUSION / MMA_M / 2, N_FUSION / MMA_N / 2] : block {
    parallel {g0, g1} by [2, 2] : group {
      mc = mma.fill 0.0;
      foreach k in K_FUSION / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mc += bias;

      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

// --- mma_loadc.co: load C accumulator from output ---
#define M_LOADC 256
#define N_LOADC 256
#define K_LOADC 256

__co__ auto matmul_loadc(f16 [M_LOADC, K_LOADC] lhs, f16 [K_LOADC, N_LOADC] rhs) {
  f16 [M_LOADC, N_LOADC] output{0.0f};

  int TILE_M = 32, TILE_N = 32, TILE_K = 16;
  int WARP_M = 8, WARP_N = 8, WARP_K = 4;

  parallel {block_m, block_n} by [cdiv(M_LOADC, TILE_M), cdiv(N_LOADC, TILE_N)] : block {
    foreach {iv_k} in [cdiv(K_LOADC, TILE_K)] {
      lhs_load_s = dma.copy lhs.chunkat(block_m, iv_k) => shared;
      rhs_load_s = dma.copy rhs.chunkat(iv_k, block_n) => shared;

      parallel {iv_warp_m, iv_warp_n} by [cdiv(TILE_M, WARP_M), cdiv(TILE_N, WARP_N)] : group {
        mc = mma.load output.chunkat(block_m#iv_warp_m, block_n#iv_warp_n);
        foreach iv_warp_k in [cdiv(TILE_K, WARP_K)] {
          ma = mma.load lhs_load_s.chunkat(iv_warp_m, iv_warp_k);
          mb = mma.load rhs_load_s.chunkat(iv_warp_k, iv_warp_n);
          mma.row.col mc, ma, mb;
        }
        mma.store mc, output.chunkat(block_m#iv_warp_m, block_n#iv_warp_n);
      }
    }
  }

  return output;
}

void mma_f16_main() {

  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 256);
    auto rhs = choreo::make_spandata<choreo::f16>(256, 256);
    lhs.fill_random(1, 10);
    rhs.fill_random(1, 10);

    auto res = matmul_group_rc(lhs.view(), rhs.view());

    float tolerance = 0.005f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        auto ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        auto delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test group_rc Passed\n" << std::endl;
  }

  {
    auto lhs = choreo::make_spandata<choreo::f16>(64, 16);
    auto rhs = choreo::make_spandata<choreo::f16>(16, 32);
    lhs.fill_random(1, 10);
    rhs.fill_random(1, 10);

    auto res = matmul_pipeline(lhs.view(), rhs.view());

    float base_tol = 0.001f;
    float rel_tol = 0.002f;
    choreo::verify_matmul_row_col_subset(lhs, rhs, res, base_tol, rel_tol, 8, 8);

    std::cout << "Test pipeline Passed\n" << std::endl;
  }

  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 256);
    auto rhs = choreo::make_spandata<choreo::f16>(256, 256);
    auto bias = choreo::make_spandata<choreo::f16>(1);
    lhs.fill_random(1, 10);
    rhs.fill_random(1, 10);
    bias.fill_random(1, 10);

    auto res = matmul_fusion_scalar(lhs.view(), rhs.view(), bias[0]);

    float tolerance = 0.005f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        auto ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        ref += __half2float(bias[0]);
        auto delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test fusion_scalar Passed\n" << std::endl;
  }

  if (false) {
    auto lhs = choreo::make_spandata<choreo::f16>(256, 256);
    auto rhs = choreo::make_spandata<choreo::f16>(256, 256);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.01f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.07f + j * 0.03f);

    auto res = matmul_loadc(lhs.view(), rhs.view());

    float tolerance = 0.007f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        __half ref = __float2half(0.0f);
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += lhs[i][k] * rhs[k][j];
        auto delta = std::abs((__half2float(ref) - __half2float(res[i][j])) / __half2float(ref));
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << __half2float(ref) << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test loadc Passed\n" << std::endl;
  }
}



// Representative PTX mma.sync cases: one per ISA variant / dtype combination.
// Covers m8n8 (Turing) and m16n8 (Ampere) tile families across major dtypes.

// ============ m8n8k4 f16->f16 (Turing, 4-group parallelism, mma.fill initializer) ============
#define M 128
#define N 256
#define K 64

__co__ auto mma_m8n8k4_f16_f16(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output;
  int MMA_M = 8, MMA_N = 8, MMA_K = 4;
  parallel {m, n} by [M / MMA_M / 4, N / MMA_N] : block {
    mc = mma.fill 0.0f;
    parallel {g0, g1} by [4, 1] : group {
      mma.fill mc, 1.5f;
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m8n8k16 s8->s32 (integer MMA, 2x2 group parallelism) ============
#define M 128
#define N 128
#define K 64

__co__ auto mma_m8n8k16_s8_s32(s8 [M, K] lhs, s8 [K, N] rhs) {
  s32 [M, N] output;
  int MMA_M = 8, MMA_N = 8, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.s32 0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m16n8k8 f16->f32 (Ampere SM80+) ============
#define M 64
#define N 128
#define K 64

__co__ auto mma_m16n8k8_f16_f32(f16 [M, K] lhs, f16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 8;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}


void ptx_mma_main() {
  float tol_f = 0.005f;

  // --- m8n8k4 f16->f16 (init bias 1.5) ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 256);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.1f + j * 0.03f);
    auto res = mma_m8n8k4_f16_f16(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 1.5f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tol_f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << __half2float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tol_f), "values are not equal.");
      }
    std::cout << "Test m8n8k4_f16_f16 Passed\n";
  }

  // --- m8n8k16 s8->s32 (exact integer match) ---
  {
    auto lhs = choreo::make_spandata<choreo::s8>(128, 64);
    auto rhs = choreo::make_spandata<choreo::s8>(64, 128);
    lhs.fill_random(-10, 10); rhs.fill_random(-10, 10);
    auto res = mma_m8n8k16_s8_s32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int32_t ref = 0;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += (lhs[i][k] * rhs[k][j]);
        if (ref != res[i][j]) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((ref == res[i][j]), "values are not equal.");
      }
    std::cout << "Test m8n8k16_s8_s32 Passed\n";
  }

  // --- m16n8k8 f16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(64, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 128);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.07f + j * 0.03f);
    auto res = mma_m16n8k8_f16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k8_f16_f32 Passed\n";
  }

  std::cout << "All Tests Passed\n" << std::endl;
}

#pragma push_macro("M")
#pragma push_macro("N")
#pragma push_macro("K")
#undef M
#undef N
#undef K

// Migrated matmul coverage.
__co__ void matmul_f16_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, 16), cdiv(N, 16)] : block {
    shared f16 [16, 16] output_s;
    parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
      mc = mma.fill 0.0;
      foreach {iv_k} in [cdiv(K, 16)] {
        lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
        rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
        wait lhs_load_s, rhs_load_s;
        foreach {iv_warp_k} in [cdiv(16, 16)] {
          ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
          mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
          mma.row.row mc, ma, mb;
        }
      }
      mma.store mc, output_s.chunkat(warp_m, warp_n);
    }
    dma.copy output_s => output.subspan(16, 16).at(block_m, block_n);
  }
}

__co__ void matmul_trans_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [N, M] output) {
  parallel {block_m, block_n} by [cdiv(M, 16), cdiv(N, 16)] : block {
    shared f16 [16, 16] output_s;
    parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
      mc = mma.fill 0.0;
      foreach {iv_k} in [cdiv(K, 16)] {
        lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
        rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
        wait lhs_load_s, rhs_load_s;
        foreach {iv_warp_k} in [cdiv(16, 16)] {
          ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
          mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
          mma.row.row mc, ma, mb;
        }
      }
      mma.store.transp mc, output_s.chunkat(warp_n, warp_m);
    }
    dma.copy output_s => output.subspan(16, 16).at(block_n, block_m);
  }
}

__co__ void matmul_persis_sta_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  int total_tiles = cdiv(M, 16) * cdiv(N, 16);
  int tiles_n = cdiv(N, 16);
  parallel block_id by 82 : block {
    shared f16 [16, 16] output_s;
    foreach {tile_iter} in [cdiv(total_tiles, 82)] {
      tile_id = tile_iter # block_id;
      if (tile_id < total_tiles) {
        block_m = tile_id / tiles_n;
        block_n = tile_id % tiles_n;
        parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
          mc = mma.fill 0.0;
          foreach {iv_k} in [cdiv(K, 16)] {
            lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
            rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
            wait lhs_load_s, rhs_load_s;
            foreach {iv_warp_k} in [cdiv(16, 16)] {
              ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
              mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
              mma.row.row mc, ma, mb;
            }
          }
          mma.store mc, output_s.chunkat(warp_m, warp_n);
        }
        dma.copy output_s => output.subspan(16, 16).at(block_m, block_n);
      }
    }
  }
}

__co__ void matmul_persis_colmajor_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  int total_tiles = cdiv(M, 16) * cdiv(N, 16);
  int tiles_m = cdiv(M, 16);
  parallel block_id by 82 : block {
    shared f16 [16, 16] output_s;
    foreach {tile_iter} in [cdiv(total_tiles, 82)] {
      tile_id = tile_iter # block_id;
      if (tile_id < total_tiles) {
        block_m = tile_id % tiles_m;
        block_n = tile_id / tiles_m;
        parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
          mc = mma.fill 0.0;
          foreach {iv_k} in [cdiv(K, 16)] {
            lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
            rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
            wait lhs_load_s, rhs_load_s;
            foreach {iv_warp_k} in [cdiv(16, 16)] {
              ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
              mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
              mma.row.row mc, ma, mb;
            }
          }
          mma.store mc, output_s.chunkat(warp_m, warp_n);
        }
        dma.copy output_s => output.subspan(16, 16).at(block_m, block_n);
      }
    }
  }
}

__co__ void matmul_persis_swizzle_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output,
                                        global s32 [T] schedule_m, global s32 [T] schedule_n) {
  int total_tiles = cdiv(M, 16) * cdiv(N, 16);
  parallel block_id by 82 : block {
    shared f16 [16, 16] output_s;
    foreach {tile_iter} in [cdiv(total_tiles, 82)] {
      tile_id = tile_iter # block_id;
      if (tile_id < total_tiles) {
        int block_m = schedule_m.at(tile_id);
        int block_n = schedule_n.at(tile_id);
        parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
          mc = mma.fill 0.0;
          foreach {iv_k} in [cdiv(K, 16)] {
            lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
            rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
            wait lhs_load_s, rhs_load_s;
            foreach {iv_warp_k} in [cdiv(16, 16)] {
              ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
              mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
              mma.row.row mc, ma, mb;
            }
          }
          mma.store mc, output_s.chunkat(warp_m, warp_n);
        }
        dma.copy output_s => output.subspan(16, 16).at(block_m, block_n);
      }
    }
  }
}

__co__ void matmul_persis_hilbert_sm86(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output,
                                        global s32 [T] schedule_m, global s32 [T] schedule_n) {
  int total_tiles = cdiv(M, 16) * cdiv(N, 16);
  parallel block_id by 82 : block {
    shared f16 [16, 16] output_s;
    foreach {tile_iter} in [cdiv(total_tiles, 82)] {
      tile_id = tile_iter # block_id;
      if (tile_id < total_tiles) {
        int block_m = schedule_m.at(tile_id);
        int block_n = schedule_n.at(tile_id);
        parallel {warp_m, warp_n} by [cdiv(16, 16), cdiv(16, 16)] : group {
          mc = mma.fill 0.0;
          foreach {iv_k} in [cdiv(K, 16)] {
            lhs_load_s = dma.copy.async lhs.subspan(16, 16).at(block_m, iv_k) => shared;
            rhs_load_s = dma.copy.async rhs.subspan(16, 16).at(block_n, iv_k) => shared;
            wait lhs_load_s, rhs_load_s;
            foreach {iv_warp_k} in [cdiv(16, 16)] {
              ma = mma.load lhs_load_s.chunkat(warp_m, iv_warp_k);
              mb = mma.load rhs_load_s.chunkat(warp_n, iv_warp_k);
              mma.row.row mc, ma, mb;
            }
          }
          mma.store mc, output_s.chunkat(warp_m, warp_n);
        }
        dma.copy output_s => output.subspan(16, 16).at(block_m, block_n);
      }
    }
  }
}


#pragma pop_macro("K")
#pragma pop_macro("N")
#pragma pop_macro("M")

int main() {
  mma_f16_main();
  ptx_mma_main();
  std::cout << "All MMA Tests Passed\n";
}

