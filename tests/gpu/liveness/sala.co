      shared event signal;
      inthreads.async (q == 0) {
        call kernel(x);
        wait signal;
        call kernel(x);
      }

      inthreads.async (q == 1) {
        call kernel(y);
        trigger signal;
      }
      sync.shared;
    }
  }
}
