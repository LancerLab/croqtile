// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// POSITIVE: Single consumer (q == 1), epilogue inside async.
// Only one physical instance exists, so within-instance
// sequential ordering suffices - no CTA barrier needed.
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_single_consumer_no_barrier() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event full;
      shared event empty;
      inthreads.async (q == 0) {
        wait empty;
        call kernel(x);
        trigger full;
      }

      inthreads.async (q == 1) {
        trigger empty;
        wait full;
        call kernel(x);
        trigger empty;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_single_consumer_no_barrier
