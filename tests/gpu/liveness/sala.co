// RUN: choreo -dv=liveness -sa=liveness -t cute -arch=sm_90a --dump-hb %s 2>&1 | FileCheck --check-prefix=LIVE %s
// RUN: choreo -es -t cute -arch=sm_90a --mem-reuse %s -o - 2>&1 | FileCheck %s
// REQUIRES: TARGET-GPU
//
// SALA (Signal-Aware Liveness Analysis) -- HB Analysis Test Cases
// Two-layer verification:
//   LIVE  - buffer liveness ranges + HB graph structure
//   CHECK - final mem-reuse codegen result (SPM allocation sizes)

// ------------------------------------------------------------
// POSITIVE: Basic signal-ordered overlap (buffer inside inthreads)
// Expected: x and y overlap (same offset)
// ------------------------------------------------------------
__co__ void pos_basic_inside() {
  parallel p by 1 : block {
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        shared f16 [16] x;
        call kernel(x);
      }

      inthreads.async (q == 1) {
        shared f16 [16] y;
        call kernel(y);
        trigger signal;
      }

      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_basic_inside
// LIVE: Phase 1 [WG0 async]
// LIVE-SAME: in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async]
// LIVE-SAME: out={{.*}}signal bufs={{{.*}}y}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_pos_basic_inside
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

