// ------------------------------------------------------------
// POSITIVE: RHS data access (xx = x.at(0)) inside inthreads
// Expected: x and y overlap
// (Tests AddUse hook via NVD -> GetAllSymbolicOperands -> DataAccess)
// ------------------------------------------------------------
__co__ void f3() {
  parallel p by 1 : block {
    shared f16 [32] x;
    shared f16 [32] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        xx = x.at(0);
      }

      inthreads.async (q == 1) {
        yy = y.at(0);
        trigger signal;
      }
      sync.shared;
    }
  }
}
