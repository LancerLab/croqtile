// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// NEGATIVE: Multi-consumer, inner-scope output buffer (like v4).
// output_s is declared INSIDE the inthreads.async (q > 0) block.
// Standard liveness says non-interfering, but multi-instance
// concurrency makes the overlap unsafe without a CTA barrier.
// Expected: x and y do NOT overlap
// ------------------------------------------------------------
__co__ void neg_inner_scope_multi_consumer() {
  parallel p by 1 : block {
    shared f16 [16] x;
    parallel q by 3 : group-4 {
      shared event full;
      shared event empty;
      inthreads.async (q == 0) {
        wait empty;
        call kernel(x);
        trigger full;
      }

      inthreads.async (q > 0) {
        trigger empty;
        wait full;
        call kernel(x);
        trigger empty;
        shared f16 [16] y;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_inner_scope_multi_consumer
// LIVE: Phase 1 [WG0 async{{.*}}bufs={{{.*}}x}
