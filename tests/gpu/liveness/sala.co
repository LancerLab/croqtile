// ------------------------------------------------------------
// POSITIVE: Multi-consumer, inner-scope output, WITH CTA barrier.
// Same as above but with sync.shared between K-loop and epilogue.
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_inner_scope_multi_consumer_with_barrier() {
  parallel p by 1 : block {
    shared f16 [16] x;
    parallel q by 3 : group-4 {
      shared event full;
      shared event empty;
      inthreads.async (q == 0) {
        wait empty;
        call kernel(x);
        trigger full;
      }

      inthreads.async (q > 0) {
        trigger empty;
        wait full;
        call kernel(x);
        trigger empty;
      }
      sync.shared;
      inthreads (q > 0) {
        shared f16 [16] y;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
