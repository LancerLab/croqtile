// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// NEGATIVE: x used at group level BEFORE inthreads
// Expected: x and y do NOT overlap
// (x is globally live because call kernel(x) is before inthreads)
// ------------------------------------------------------------
__co__ void neg_pre_inthreads() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      call kernel(x);
      inthreads.async (q == 0) {
        wait signal;
      }
      inthreads.async (q == 1) {
        call kernel(y);
        trigger signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_pre_inthreads
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_pre_inthreads
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// NEGATIVE: one buffer inside, one buffer at group level via .at()
// Expected: x and y do NOT overlap
// (y.at(0) = 1.0f at group level makes y globally live)
// ------------------------------------------------------------
__co__ void neg_group_level_at() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        call kernel(x);
      }
      inthreads.async (q == 1) {
        trigger signal;
      }
      y.at(0) = 1.0f;
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_group_level_at
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={}
// CHECK-LABEL: __choreo_device_neg_group_level_at
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: foreach inside inthreads with signal ordering
// Expected: x and y overlap
// (Signal ordering holds across loop iterations)
// ------------------------------------------------------------
__co__ void pos_foreach_inside() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        foreach {i} in [4] {
          call kernel(x);
        }
      }

      inthreads.async (q == 1) {
        foreach {j} in [4] {
          call kernel(y);
        }
        trigger signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_foreach_inside
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={{{.*}}y}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_pos_foreach_inside
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// NEGATIVE: foreach at group level (outside inthreads) uses buffer
// Expected: x and y do NOT overlap
// (x accessed in group-level foreach -> globally live)
// ------------------------------------------------------------
__co__ void neg_foreach_group() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
      }
      inthreads.async (q == 1) {
        call kernel(y);
        trigger signal;
      }
      foreach {k} in [4] {
        call kernel(x);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_foreach_group
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_foreach_group
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: one buffer per inthreads, foreach only on loop index
// Expected: x and y overlap
// (foreach inside inthreads doesn't change the HB ordering)
// ------------------------------------------------------------
__co__ void pos_foreach_and_at() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        foreach {i} in [4] {
          xx = x.at(i);
        }
      }

      inthreads.async (q == 1) {
        foreach {j} in [4] {
          y.at(j) = 1.0f;
        }
        trigger signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_foreach_and_at
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={{{.*}}y}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_pos_foreach_and_at
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// POSITIVE: Pipeline with bidirectional signals (cyclic)
// WG0: trigger empty; foreach { wait sig; use(x); trigger empty; }
// WG1: foreach { wait empty; use(y); trigger sig; }
// Expected: x and y DO overlap (128 bytes total)
// Reasoning: back-edge (phase 5 -> phase 2 via sig) is skipped to
// prevent cycles, but the forward edge (phase 2 -> phase 5 via empty)
// proves ordering within one iteration. The signals enforce mutual
// exclusion across iterations too (ping-pong pattern).
// ------------------------------------------------------------
__co__ void neg_pipeline_cyclic() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event sig;
      shared event empty;
      inthreads.async (q == 0) {
        trigger empty;
        foreach {i} in [4] {
          wait sig;
          call kernel(x);
          trigger empty;
        }
      }

      inthreads.async (q == 1) {
        foreach {j} in [4] {
          wait empty;
          call kernel(y);
          trigger sig;
        }
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_pipeline_cyclic
// LIVE: HB Graph (7 phases):
// LIVE: Phase 2 [WG0 async{{.*}}in={{.*}}sig{{.*}}bufs={{{.*}}x}
// LIVE: Phase 5 [WG1 async{{.*}}in={{.*}}empty{{.*}}bufs={{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_pipeline_cyclic
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// NEGATIVE: Same buffer accessed in BOTH inthreads groups
// Expected: x and y do NOT overlap (x co-live in both WGs)
// (x is in same phase in WG0 AND WG1 -> not overlappable with y)
// ------------------------------------------------------------
__co__ void neg_shared_across_wgs() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        call kernel(x);
      }

      inthreads.async (q == 1) {
        call kernel(x);
        call kernel(y);
        trigger signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_shared_across_wgs
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}signal bufs={{{.*}}x,{{.*}}y}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_neg_shared_across_wgs
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Three WG scenario (3 warp groups)
// WG0: wait s1; use(a)
// WG1: use(b); trigger s1; trigger s2
// WG2: wait s2; use(c)
// Expected: (a,b) overlap and (b,c) overlap
// (b->s1->a and b->s2->c)
// NOTE: Need parallel q by 3 : group-4
// ------------------------------------------------------------
__co__ void pos_three_wgs() {
  parallel p by 1 : block {
    shared f16 [16] a;
    shared f16 [16] b;
    shared f16 [16] c;
    parallel q by 3 : group-4 {
      shared event evt1;
      shared event evt2;
      inthreads.async (q == 0) {
        wait evt1;
        call kernel(a);
      }

      inthreads.async (q == 1) {
        call kernel(b);
        trigger evt1;
        trigger evt2;
      }

      inthreads.async (q == 2) {
        wait evt2;
        call kernel(c);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_three_wgs
// LIVE: HB Graph (7 phases):
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}evt1 bufs={{{.*}}a}
// LIVE: Phase 2 [WG1 async{{.*}}out={{.*}}evt1 bufs={{{.*}}b}
// LIVE: Phase 6 [WG2 async{{.*}}in={{.*}}evt2 bufs={{{.*}}c}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_pos_three_wgs
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: a = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: b = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: c = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Signal from WG0 to WG1, then WG1 to WG0
// WG0: use(a); trigger evt1; wait evt2; use(c)
// WG1: wait evt1; use(b); trigger evt2
// Expected: (a,b) overlap, (b,c) overlap, (a,c) NOT overlap (same WG)
// a and c are in same WG0 with sequential ordering,
// but they're in different phases separated by signals
// ------------------------------------------------------------
__co__ void pos_ping_pong() {
  parallel p by 1 : block {
    shared f16 [16] a;
    shared f16 [16] b;
    shared f16 [16] c;
    parallel q by 2 : group-4 {
      shared event evt1;
      shared event evt2;
      inthreads.async (q == 0) {
        call kernel(a);
        trigger evt1;
        wait evt2;
        call kernel(c);
      }

      inthreads.async (q == 1) {
        wait evt1;
        call kernel(b);
        trigger evt2;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_ping_pong
// LIVE: HB Graph (6 phases):
// LIVE: Phase 0 [WG0 async{{.*}}out={{.*}}evt1 bufs={{{.*}}a}
// LIVE: Phase 2 [WG0 async{{.*}}in={{.*}}evt2 bufs={{{.*}}c}
// LIVE: Phase 4 [WG1 async{{.*}}in={{.*}}evt1{{.*}}out={{.*}}evt2 bufs={{{.*}}b}
// LIVE: 0 -->hb 4
// LIVE: 4 -->hb 2
// CHECK-LABEL: __choreo_device_pos_ping_pong
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: a = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: b = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: c = (f16*)(anon_{{[0-9]+}} + 0)

// ============================================================
// Multi-consumer CTA barrier tests
// ============================================================

// ------------------------------------------------------------
// NEGATIVE: Multi-consumer, epilogue inside async block, no barrier.
// 3 consumers (q > 0) share one async block.  Different physical
// instances can be at different phases simultaneously, so
// pipeline buffers (x) and epilogue buffer (y) may race.
// Expected: x and y do NOT overlap
// ------------------------------------------------------------
__co__ void neg_multi_consumer_no_barrier() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 4 : group-4 {
      shared event full;
      shared event empty;
      inthreads.async (q == 0) {
        wait empty;
        call kernel(x);
        trigger full;
      }

      inthreads.async (q > 0) {
        trigger empty;
        wait full;
        call kernel(x);
        trigger empty;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_multi_consumer_no_barrier
// LIVE: Phase 1 [WG0 async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 5 [WG1 multi async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 6 [WG1 multi async{{.*}}bufs={{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_multi_consumer_no_barrier
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Multi-consumer with CTA barrier before epilogue.
// Same structure as above, but epilogue is in a separate sync
// inthreads block after sync.shared.  The CTA barrier ensures
// all consumer instances finish the pipeline before any starts
// the epilogue.
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_multi_consumer_with_barrier() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 4 : group-4 {
      shared event full;
      shared event empty;
      inthreads.async (q == 0) {
        wait empty;
        call kernel(x);
        trigger full;
      }

      inthreads.async (q > 0) {
        trigger empty;
        wait full;
        call kernel(x);
        trigger empty;
      }

      sync.shared;

      inthreads (q > 0) {
        call kernel(y);
      }
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_multi_consumer_with_barrier
// LIVE: Phase 1 [WG0 async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 5 [WG1 multi async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 7 [WG1 multi cta-bar{{.*}}bufs={{{.*}}y}
