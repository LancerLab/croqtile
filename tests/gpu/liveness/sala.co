// ------------------------------------------------------------
// POSITIVE: Multiple signals creating a chain: c -> sig1 -> a -> b, d -> sig2 -> b
// WG0: wait sig1, use a, wait sig2, use b
// WG1: use c, trigger sig1, use d, trigger sig2
// Signal chain: Phase3(c) ->hb Phase1(a) ->hb Phase2(b), Phase4(d) ->hb Phase2(b)
// Expected: a,b,c all overlap at offset 0; d separate (interferes with a)
// ------------------------------------------------------------
__co__ void pos_multi_signal_independent() {
  parallel p by 1 : block {
    shared f16 [16] a;
    shared f16 [16] b;
    shared f16 [16] c;
    shared f16 [16] d;
    parallel q by 2 : group-4 {
      shared event sig1;
      shared event sig2;
      inthreads.async (q == 0) {
        wait sig1;
        call kernel(a);
        wait sig2;
        call kernel(b);
      }

      inthreads.async (q == 1) {
        call kernel(c);
        trigger sig1;
        call kernel(d);
        trigger sig2;
      }
      sync.shared;
    }
  }
}
