// ------------------------------------------------------------
// POSITIVE: Buffer used between trigger and end of inthreads
// WG0: use x, trigger signal
// WG1: wait signal, use y
// Key: x's last use is BEFORE trigger, so x hb y
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_use_before_trigger() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        call kernel(x);
        trigger signal;
      }

      inthreads.async (q == 1) {
        wait signal;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
