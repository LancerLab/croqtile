// ------------------------------------------------------------
// POSITIVE: Buffers declared at group level
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_basic_group() {
  parallel p by 1 : block {
    parallel q by 2 : group-4 {
      shared event signal;
      shared f16 [16] x;
      inthreads.async (q == 0) {
        wait signal;
        call kernel(x);
      }
      
      shared f16 [16] y;
      inthreads.async (q == 1) {
        call kernel(y);
        trigger signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_basic_group
// LIVE: Phase 1 [WG0 async]
// LIVE-SAME: in={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 2 [WG1 async]
// LIVE-SAME: out={{.*}}signal bufs={{{.*}}y}
// LIVE: 2 -->hb 1
// CHECK-LABEL: __choreo_device_pos_basic_group
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// POSITIVE: Three buffers, two signal boundaries
// WG1: use(a), trigger s1, use(b), trigger s2
// WG0: wait s1, use(c), wait s2, ...
// Expected: a and c overlap (s1 orders them)
//           b and c may or may not overlap depending on phase ordering
// ------------------------------------------------------------
__co__ void pos_three_bufs_chain() {
  parallel p by 1 : block {
    shared f16 [16] a;
    shared f16 [16] b;
    shared f16 [16] c;
    parallel q by 2 : group-4 {
      shared event sig1;
      shared event sig2;
      inthreads.async (q == 0) {
        wait sig1;
        call kernel(c);
        wait sig2;
      }

      inthreads.async (q == 1) {
        call kernel(a);
        trigger sig1;
        call kernel(b);
        trigger sig2;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_three_bufs_chain
// LIVE: HB Graph (6 phases):
// LIVE: Phase 1 [WG0 async{{.*}}in={{.*}}sig1 bufs={{{.*}}c}
// LIVE: Phase 3 [WG1 async{{.*}}out={{.*}}sig1 bufs={{{.*}}a}
// LIVE: Phase 4 [WG1 async{{.*}}out={{.*}}sig2 bufs={{{.*}}b}
// LIVE: 3 -->hb 1
// CHECK-LABEL: __choreo_device_pos_three_bufs_chain
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: a = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: b = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: c = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Reverse direction - WG0 triggers, WG1 waits
// Expected: x and y overlap
// ------------------------------------------------------------
__co__ void pos_reverse_direction() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        call kernel(x);
        trigger signal;
      }

      inthreads.async (q == 1) {
        wait signal;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_reverse_direction
// LIVE: Phase 0 [WG0 async{{.*}}out={{.*}}signal bufs={{{.*}}x}
// LIVE: Phase 3 [WG1 async{{.*}}in={{.*}}signal bufs={{{.*}}y}
// LIVE: 0 -->hb 3
// CHECK-LABEL: __choreo_device_pos_reverse_direction
// CHECK: anon_{{[0-9]+}}[128]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 0)

// ------------------------------------------------------------
// NEGATIVE: Both buffers accessed in same WG, same phase
// Expected: x and y do NOT overlap (co-live in same phase)
// ------------------------------------------------------------
__co__ void neg_same_phase() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        call kernel(x);
        call kernel(y);
        trigger signal;
      }

      inthreads.async (q == 1) {
        wait signal;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_same_phase
// LIVE: Phase 0 [WG0 async{{.*}}bufs={{{.*}}x,{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_same_phase
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// NEGATIVE: No signal at all - concurrent access
// Expected: x and y do NOT overlap (no HB ordering between WGs)
// ------------------------------------------------------------
__co__ void neg_no_signal() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      inthreads.async (q == 0) {
        call kernel(x);
      }

      inthreads.async (q == 1) {
        call kernel(y);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_no_signal
// LIVE: HB Graph (2 phases):
// LIVE: Phase 0 [WG0 async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 1 [WG1 async{{.*}}bufs={{{.*}}y}
// LIVE-NEXT: Reachability:
// LIVE-NOT: -->hb
// LIVE: digraph
// CHECK-LABEL: __choreo_device_neg_no_signal
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// NEGATIVE: Cyclic signals (like FA K/V back-edge)
// WG0 (producer): wait empty, use(x), trigger full, wait empty, use(y), trigger full
// WG1 (consumer): trigger empty (init), wait full, use(x), trigger empty, wait full, use(y), trigger empty
// The back-edge (trigger empty -> wait empty) creates a cycle.
// x and y accessed in both WGs with complementary full/empty signals.
// Expected: x and y do NOT overlap (acyclic constraint rejects back-edges)
// ------------------------------------------------------------
__co__ void neg_cyclic_back_edge() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event x_full;
      shared event x_empty;
      shared event y_full;
      shared event y_empty;
      inthreads.async (q == 0) {
        wait x_empty;
        call write_x(x);
        trigger x_full;
        wait y_empty;
        call write_y(y);
        trigger y_full;
      }

      inthreads.async (q == 1) {
        trigger x_empty;
        trigger y_empty;
        wait x_full;
        call read_x(x);
        trigger x_empty;
        wait y_full;
        call read_y(y);
        trigger y_empty;
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::neg_cyclic_back_edge
// LIVE: HB Graph (12 phases):
// LIVE: Phase 1 [WG0 async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 3 [WG0 async{{.*}}bufs={{{.*}}y}
// LIVE: Phase 8 [WG1 async{{.*}}bufs={{{.*}}x}
// LIVE: Phase 10 [WG1 async{{.*}}bufs={{{.*}}y}
// CHECK-LABEL: __choreo_device_neg_cyclic_back_edge
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: x = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: y = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Same buffer in different phases of same WG (within-WG ordering)
// and different buffers in different WGs with signal ordering.
// WG0: use(a), trigger s, use(b)
// WG1: wait s, use(c)
// Expected: a and c overlap (a before trigger, c after wait)
//           a and b do NOT overlap (a and b both in WG0 same phase? 
//           Actually a and b are in different phases separated by trigger s)
//           b and c: b is after trigger s in WG0, c is after wait s in WG1.
//           b and c are concurrent (no ordering between post-trigger and post-wait in same signal)
// ------------------------------------------------------------
__co__ void pos_mixed_ordering() {
  parallel p by 1 : block {
    shared f16 [16] a;
    shared f16 [16] b;
    shared f16 [16] c;
    parallel q by 2 : group-4 {
      shared event sig;
      inthreads.async (q == 0) {
        call kernel(a);
        trigger sig;
        call kernel(b);
      }

      inthreads.async (q == 1) {
        wait sig;
        call kernel(c);
      }
      sync.shared;
    }
  }
}
// LIVE-LABEL: Built HB graph for scope '::pos_mixed_ordering
// LIVE: Phase 0 [WG0 async{{.*}}out={{.*}}sig bufs={{{.*}}a}
// LIVE: Phase 1 [WG0 async{{.*}}bufs={{{.*}}b}
// LIVE: Phase 3 [WG1 async{{.*}}in={{.*}}sig bufs={{{.*}}c}
// LIVE: 0 -->hb 3
// CHECK-LABEL: __choreo_device_pos_mixed_ordering
// CHECK: anon_{{[0-9]+}}[256]
// CHECK: a = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: b = (f16*)(anon_{{[0-9]+}} + 0)
// CHECK: c = (f16*)(anon_{{[0-9]+}} + 128)

// ------------------------------------------------------------
// POSITIVE: Different-sized buffers overlap
// Expected: x(128B) and y(64B) overlap at same offset
// SMEM = max(128,64) = 128 instead of 192
// ------------------------------------------------------------
__co__ void pos_different_sizes() {
  parallel p by 1 : block {
    shared f16 [64] x;
    shared f16 [32] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        wait signal;
        call kernel(x);
      }

      inthreads.async (q == 1) {
        call kernel(y);
        trigger signal;
      }
      sync.shared;
    }
  }
}
