// ------------------------------------------------------------
// NEGATIVE: Buffer used AFTER trigger (same WG still accesses after signal)
// WG0: trigger signal, THEN use x (x lives beyond the trigger)
// WG1: wait signal, use y
// Since x is used after trigger, x and y could be concurrent
// Expected: x and y do NOT overlap
// ------------------------------------------------------------
__co__ void neg_use_after_trigger() {
  parallel p by 1 : block {
    shared f16 [16] x;
    shared f16 [16] y;
    parallel q by 2 : group-4 {
      shared event signal;
      inthreads.async (q == 0) {
        trigger signal;
        call kernel(x);
      }

      inthreads.async (q == 1) {
        wait signal;
        call kernel(y);
      }
      sync.shared;
    }
  }
}
