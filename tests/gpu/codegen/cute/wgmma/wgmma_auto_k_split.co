// REQUIRES: TARGET-SM_90A
// RUN: choreo -es -t cute -arch=sm_90a %s -o - | FileCheck %s --check-prefix=ROW-ROW
// RUN: choreo -es -t cute -arch=sm_90a %s -o - | FileCheck %s --check-prefix=ROW-COL

#define M 64
#define N 128
#define K 64

__co__ auto direct_row_row_auto_split(f16 [2 * M, K] lhs, f16 [N, K] rhs) {
  f16 [2 * M, N] output{0.0f};

  parallel pb by 1 : block {
    lhs_s = dma.copy.swiz<128> lhs => shared;
    rhs_s = dma.copy.swiz<128> rhs => shared;

    parallel wgm by 2 : group-4 {
      mc = mma.fill.f32 0.0f;
      mma.row.row mc, lhs_s.chunkat(wgm, _), rhs_s;
      mma.store mc, output.subspan(M, N).at(wgm, 0);
    }
  }

  return output;
}

__co__ auto direct_row_col_auto_split(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output{0.0f};

  parallel pb by 1 : block {
    lhs_s = dma.copy.swiz<128> lhs => shared;
    rhs_s = dma.copy.swiz<128> rhs => shared;

    parallel g by 1 : group-4 {
      mc = mma.fill.f32 0.0f;
      mma.row.col mc, lhs_s, rhs_s;
      mma.store mc, output;
    }
  }

  return output;
}

// ROW-ROW: for (int __choreo_wgmma_k_iter = 0; __choreo_wgmma_k_iter < 4; ++__choreo_wgmma_k_iter) {
// ROW-ROW: auto* __choreo_wgmma_ptr_{{[0-9]+}}_iter = (f16*)
// ROW-ROW: uint64_t __choreo_wgmma_desc_{{[0-9]+}}_iter = wgmma_make_smem_desc<WGMMA_MajorOrder::K_MAJOR, WGMMA_Swizzle::B128>
// ROW-ROW: auto* __choreo_wgmma_ptr_{{[0-9]+}}_iter = (f16*)
// ROW-ROW: uint64_t __choreo_wgmma_desc_{{[0-9]+}}_iter = wgmma_make_smem_desc<WGMMA_MajorOrder::K_MAJOR, WGMMA_Swizzle::B128>
// ROW-ROW: MMA_64x128x16_F32F16F16_SS<static_cast<cute::SM90::GMMA::Major>(0), static_cast<cute::SM90::GMMA::Major>(0)>::fma(__choreo_wgmma_desc_{{[0-9]+}}_iter, __choreo_wgmma_desc_{{[0-9]+}}_iter
// ROW-ROW: warpgroup_commit_batch();
// ROW-ROW-NEXT: warpgroup_wait<0>();
// ROW-ROW-NEXT: warpgroup_fence_operand(mc);

// ROW-COL: for (int __choreo_wgmma_k_iter = 0; __choreo_wgmma_k_iter < 4; ++__choreo_wgmma_k_iter) {
// ROW-COL: auto* __choreo_wgmma_ptr_{{[0-9]+}}_iter = (f16*)
// ROW-COL: uint64_t __choreo_wgmma_desc_{{[0-9]+}}_iter = wgmma_make_smem_desc<WGMMA_MajorOrder::K_MAJOR, WGMMA_Swizzle::B128>
// ROW-COL: auto* __choreo_wgmma_ptr_{{[0-9]+}}_iter = (f16*)
// ROW-COL: uint64_t __choreo_wgmma_desc_{{[0-9]+}}_iter = wgmma_make_smem_desc<WGMMA_MajorOrder::MN_MAJOR, WGMMA_Swizzle::B128>
// ROW-COL: MMA_64x128x16_F32F16F16_SS<static_cast<cute::SM90::GMMA::Major>(0), static_cast<cute::SM90::GMMA::Major>(1)>::fma(__choreo_wgmma_desc_{{[0-9]+}}_iter, __choreo_wgmma_desc_{{[0-9]+}}_iter
// ROW-COL: warpgroup_commit_batch();
// ROW-COL-NEXT: warpgroup_wait<0>();
// ROW-COL-NEXT: warpgroup_fence_operand(mc);