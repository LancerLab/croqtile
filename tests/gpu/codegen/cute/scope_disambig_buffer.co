// RUN: choreo -n -es -t cute -arch=sm_86 %s -o - 2>&1 | FileCheck %s
//
// Test: Nested parallel blocks declaring shared buffers with the same name
// produce distinct names in generated code (no C++ redefinition).

__co__ auto foo(f16 [128, 128] lhs, f16 [128] temp) {
  f16 [128, 128] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [128 / MMA_M / 4, 128 / MMA_N] : block {
    local f16[128] buf;
    parallel {g0, g1} by [4, 1]: group {
      local f16[128] buf;
    }
  }
  return output;
}

// First `buf` keeps original name, nested `buf` gets a suffix.
// CHECK: f16 buf[128];
// CHECK: f16 buf__1[128];
