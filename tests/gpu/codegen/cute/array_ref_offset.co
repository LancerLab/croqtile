// RUN: choreo -es -t cute -arch=sm_86 %s -o - | FileCheck %s
//
// Verify that array element references on spanned arrays with memory reuse
// produce correct linearized pointer offsets (LinearizeArrayOffset).

// --- Full subscription on a 2D array ---
__co__ void test_array_ref_full() {
  parallel p by 1 : block {
    shared f32[32] s[4][2];
    s0 = s[1][1];
  }
}
// CHECK-LABEL: __global__
// CHECK: float* s0 = (float*)(s + ((1)*2+1)*(32));

// --- Partial subscription on a 1D array ---
__co__ void test_array_ref_partial() {
  parallel p by 1 : block {
    shared f32[16] s[3];
    s0 = s[2];
  }
}
// CHECK: float* s0 = (float*)(s + (2)*(16));

// --- Full subscription with span_as ---
__co__ void test_array_span_as() {
  parallel p by 1 : block {
    shared f32[32] s[4][2];
    s0 = s[1][1].span_as(4, 8);
  }
}
// CHECK: auto* s0 = static_cast<float*>(s + ((1)*2+1)*(32));

// --- Partial subscription with span_as ---
__co__ void test_array_span_as_partial() {
  parallel p by 1 : block {
    shared f32[32] s[4][2];
    s0 = s[3].span_as(4, 8);
  }
}
// CHECK: auto* s0 = static_cast<float*>(s + ((3)*2)*(32));

// --- 3D array full subscription ---
__co__ void test_3d_array_ref() {
  parallel p by 1 : block {
    shared f32[8] s[2][3][4];
    s0 = s[1][2][3];
  }
}
// CHECK: float* s0 = (float*)(s + (((1)*3+2)*4+3)*(8));


__co__ void test_array_ref_full_local(int x, int N) {
  parallel p by 1 : block {
    local f32[N] sdyn[4];
    sdyn0 = sdyn[x % N];
  }
}
// CHECK: float* sdyn = (float*)(anon_{{.*}} + {{.*}});
// CHECK: float* sdyn0 = (float*)(sdyn + ((x % N))*(N));