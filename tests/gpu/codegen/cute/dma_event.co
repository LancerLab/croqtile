// REQUIRES: TARGET-SM_90A
// RUN: choreo -es --use-warpspec -t cute -arch=sm_90a %s -o - 2>&1 | FileCheck %s

__co__ void foo(f32 [128, 128] input) {
  
  parallel b by 1 : block {
    parallel g by 2 : group-4 {
      shared f32 [128, 128] input_s;
      shared event full[2];
      
      inthreads (g == 0) {
        foreach {stage} in [2]
          tma.copy.async<full[stage]> input.chunkat(_, _) => input_s;
      }

      inthreads (g == 1) {
        foreach {stage} in [2]
          wait full[stage];
      }
    }
  }
}

// CHECK: choreo::tma_load_2d_shared_cta_global_mbarrier((void*)input_s, (const void*)&__choreo_tma_0_tensor_map, (uint64_t*)&(full[__iv_stage]), 0, 0);
// CHECK: full[__iv_stage].wait(full__phase[__iv_stage]);