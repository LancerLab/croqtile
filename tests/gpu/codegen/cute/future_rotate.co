// RUN: choreo -es -t cute -arch=sm_86 %s -o - | FileCheck %s
//
// Verify codegen for complex triple-rotate pipeline with futures:
//  - dma.any future declarations
//  - choreo::rotate() calls for both shared and output futures
//  - local spanned array used as output staging buffer
//  - correct prologue / steady-state / epilogue structure

__co__ void test_triple_rotate(
  bf16 [B, T, H, K] q,
  bf16 [B, T, H, V] v,
  bf16 [B, T, H, V] o
) {
  int BK = 64;
  int BV = 32;
  int NK = cdiv(K, BK);
  int NV = cdiv(V, BV);
  o_f0 = dma.any;
  o_f1 = dma.any;
  o_f2 = dma.any;
  parallel {i_k, i_v, i_n} by [NK, NV, B] : block {
    with i_t in T {
      q_s0 = dma.any;
      q_s1 = dma.any;
      q_s2 = dma.any;
      v_s0 = dma.any;
      v_s1 = dma.any;
      v_s2 = dma.any;

      local bf16 [BV] o_l[3];

      // prologue-0
      q_s2 = dma.copy.async q.span_as([B * T, H, K])
                             .view(T, H, K).from(i_n * T, 0, 0)
                             .chunkat(i_t, _, i_k) => shared;
      v_s2 = dma.copy.async v.span_as([B * T, H, V])
                             .view(T, H, V).from(i_n * T, 0, 0)
                             .chunkat(i_t, _, i_v) => shared;

      // prologue-1
      q_s1 = dma.copy.async q.span_as([B * T, H, K])
                             .view(T, H, K).from(i_n * T, 0, 0)
                             .chunkat(i_t(1), _, i_k) => shared;
      v_s1 = dma.copy.async v.span_as([B * T, H, V])
                             .view(T, H, V).from(i_n * T, 0, 0)
                             .chunkat(i_t(1), _, i_v) => shared;

      wait q_s2, v_s2;
      rotate(q_s0, q_s1, q_s2);
      rotate(v_s0, v_s1, v_s2);
      rotate(o_f0, o_f1, o_f2);

      // steady state
      foreach i_t(2:-2:) {
        q_s0 = dma.copy.async q.span_as([B * T, H, K])
                               .view(T, H, K).from(i_n * T, 0, 0)
                               .chunkat(i_t, _, i_k) => shared;
        v_s0 = dma.copy.async v.span_as([B * T, H, V])
                               .view(T, H, V).from(i_n * T, 0, 0)
                               .chunkat(i_t, _, i_v) => shared;

        wait q_s2, v_s2;
        wait o_f2;
        o_f2 = dma.copy.async o_l[(i_t - 2) % 3]
                  => o.span_as([B * T, H, V])
                  .view(T, _, _).from(i_n * T, 0, 0)
                  .chunkat(i_t, _, i_v)
                  .span_as([BV]);

        rotate(q_s0, q_s1, q_s2);
        rotate(v_s0, v_s1, v_s2);
        rotate(o_f0, o_f1, o_f2);
      }

      // epilogue-0
      wait q_s2, v_s2;
      wait o_f2;
      o_f2 = dma.copy.async o_l[(T - 2) % 3]
                => o.span_as([B * T, H, V])
                .view(T, _, _).from(i_n * T, 0, 0)
                .chunkat(i_t(-2), _, i_v)
                .span_as([BV]);
      rotate(o_f0, o_f1, o_f2);

      // epilogue-1
      wait o_f2;
      o_f2 = dma.copy.async o_l[(T - 1) % 3]
                => o.span_as([B * T, H, V])
                .view(T, _, _).from(i_n * T, 0, 0)
                .chunkat(i_t(-1), _, i_v)
                .span_as([BV]);
      wait o_f0, o_f1, o_f2;
    }
  }
}

// -- shared future buffer declarations with memory-reuse offsets --
// CHECK: bf16* q_s0__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}q_s0__buf__);
// CHECK: bf16* q_s1__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}q_s1__buf__);
// CHECK: bf16* q_s2__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}q_s2__buf__);
// CHECK: bf16* v_s0__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}v_s0__buf__);
// CHECK: bf16* v_s1__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}v_s1__buf__);
// CHECK: bf16* v_s2__buf__ = (bf16*)(anon_{{[0-9]+}} + mr_offset_{{.*}}v_s2__buf__);

// -- local output staging array --
// CHECK: bf16 o_l[(3)*(32)];

// -- prologue: rotate shared and output futures --
// CHECK: choreo::rotate(q_s0, q_s1, q_s2);
// CHECK: choreo::rotate(v_s0, v_s1, v_s2);

// -- output futures declared via rotate --
// CHECK: future o_f0("o_f0"
// CHECK: future o_f1("o_f1"
// CHECK: future o_f2("o_f2"
// CHECK: choreo::rotate(o_f0, o_f1, o_f2);

// -- steady-state loop with all three rotates --
// CHECK: auto [[ANON:[A-Za-z0-9_]+]] = 2;
// CHECK: for (__iv_i_t__elem__0 = ([[ANON]]);
// CHECK:   choreo::rotate(q_s0, q_s1, q_s2);
// CHECK:   choreo::rotate(v_s0, v_s1, v_s2);
// CHECK:   choreo::rotate(o_f0, o_f1, o_f2);

// -- epilogue rotates --
// CHECK: choreo::rotate(o_f0, o_f1, o_f2);

// -- final waits --
// CHECK: o_f0.wait();
// CHECK: o_f1.wait();
// CHECK: o_f2.wait();
