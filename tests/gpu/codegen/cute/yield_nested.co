// RUN: choreo -es -t cute -arch=sm_90a %s -o - 2>&1 | FileCheck %s

__co__ void foo(int x) {
  parallel by 1 : block {
    parallel by 256 : thread {
      if (x == 0) {
        yield;
      }
    }
    if (x == 0) {
      println("here");
    }
  }
  println("there");
}

// yield exits the entire __global__ device function;
// code after yield in the kernel is skipped, but host code runs normally
// CHECK: __global__ void __choreo_device_foo(int x)
// CHECK: if ((x == 0)) {
// CHECK-NEXT: return;
// CHECK-NEXT: }
// CHECK: printf("here\n");
// CHECK: void foo(int x)
// CHECK: __choreo_device_foo<<<
// CHECK: printf("there\n");
