// REQUIRES: TARGET-SM_90A
// RUN: choreo -es -t cute -arch=sm_90a %s -o - | grep -v "\<CHECK\>" | FileCheck %s

#define TILE_M 64
#define TILE_K 64

__co__ void test_copy_if_g2s(f16 [M, K] input) {
  parallel {block_m, block_k} by [cdiv(M, TILE_M), cdiv(K, TILE_K)] : block
  parallel wg by 1 : group-4 {
    shared f16 [TILE_M, TILE_K] s_tail_m;
    shared f16 [TILE_M, TILE_K] s_tail_k;
    shared f16 [TILE_M, TILE_K] s_tail_mk;

    base_m = block_m * TILE_M;
    base_k = block_k * TILE_K;
    remain_m = M - base_m;
    remain_k = K - base_k;
    TM = (TILE_M < remain_m) ? TILE_M : remain_m;
    TK = (TILE_K < remain_k) ? TILE_K : remain_k;

    dma.copy.swiz<128>.zfill
      input.view(TM, TILE_K).from(base_m, 0) => s_tail_m;

    dma.copy.swiz<128>.zfill
      input.view(TILE_M, TK).from(0, base_k) => s_tail_k;

    dma.copy.swiz<128>.zfill
      input.view(TM, TK).from(base_m, base_k) => s_tail_mk;
  }
}

int main() { return 0; }

// CHECK: if (K % 8 == 0) {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::SM80_CP_ASYNC_CACHEGLOBAL_ZFILL<cute::uint128_t>, f16>, 16, 8, 1, 8, true, true, true>(__tensor1_input, __tensor2_s_tail_m,
// CHECK: } else {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::AutoVectorizingCopyWithAssumedAlignment<16>, f16>, 16, 8, 4, 8, true, true, true>(__tensor1_input, __tensor2_s_tail_m,
// CHECK: }
// CHECK: if (K % 8 == 0 && (TK) % 8 == 0) {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::SM80_CP_ASYNC_CACHEGLOBAL_ZFILL<cute::uint128_t>, f16>, 16, 8, 1, 8, true, true, true>(__tensor3_input, __tensor4_s_tail_k,
// CHECK: } else {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::AutoVectorizingCopyWithAssumedAlignment<16>, f16>, 16, 8, 4, 8, true, true, true>(__tensor3_input, __tensor4_s_tail_k,
// CHECK: }
// CHECK: if (K % 8 == 0 && (TK) % 8 == 0) {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::SM80_CP_ASYNC_CACHEGLOBAL_ZFILL<cute::uint128_t>, f16>, 16, 8, 1, 8, true, true, true>(__tensor5_input, __tensor6_s_tail_mk,
// CHECK: } else {
// CHECK:   choreo::tiled_copy<cute::Copy_Atom<cute::AutoVectorizingCopyWithAssumedAlignment<16>, f16>, 16, 8, 4, 8, true, true, true>(__tensor5_input, __tensor6_s_tail_mk,
// CHECK: }