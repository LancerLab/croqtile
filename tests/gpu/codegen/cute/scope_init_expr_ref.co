// RUN: choreo -es -t cute -arch=sm_86 %s -o - 2>&1 | FileCheck %s
//
// Test: The init expression of a new variable should reference the outer
// scope value, not itself. `int y = x + 1` should use the parameter `x`.

__co__ void bar(int x) {
  parallel p by 1 {
    int y = x + 1;
    println(y);
  }
}

// The initialized value should be captured in `y` without self-referencing.
// CHECK: __global__ void __choreo_device_bar
// CHECK: printf("%lld\n", static_cast<long long>(y));
