// RUN: choreo -es -t cute -arch=sm_90a %s 2>&1 | FileCheck %s

#define LEN 128

// CHECK-LABEL: __choreo_device_test_frag_copy
__co__ void test_frag_copy() {
  parallel t by 128 : thread {
    frag f32[LEN] a {1.0f};
    frag f32[LEN] b {0.0f};
    // CHECK: { // frag.copy
    // CHECK-NEXT: #pragma unroll
    // CHECK-NEXT: for (int __r = 0; __r < 1; ++__r)
    // CHECK-NEXT: b[__r] = a[__r];
    // CHECK: } // frag.copy
    copy(b, a);
  }
}
