#define BLOCK_M 64
#define BLOCK_N 64

// RUN: choreo -es -t cute %s 2>&1 | FileCheck %s

__co__ void automap_basic() {
  parallel t by 128 : thread {
    frag f32[BLOCK_M] row;
    frag f32[BLOCK_M, BLOCK_N] tile;

    apply {i} in row.span
      row.at(i) = 1.0f;

    apply {i, j} in tile.span
      tile.at(i, j) = row.at(i);
  }
}

