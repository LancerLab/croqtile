// RUN: choreo -es -dv=assert-site %s -o /dev/null 2>&1 | FileCheck %s

// -----------------------------------------------------------------------
// ENTRY assertion: select(xx, …) where xx is a parameter.
// Since xx is a parameter (does not change within the function), the
// assertion is classified directly as ENTRY — no promotion needed.
// The AssertSite pass only processes DEF_SITE assertions, so no
// [assert-site] log message is produced for these.
// -----------------------------------------------------------------------

__co__ void foo(int xx) {
  global s32[1,2] g;
  parallel by 1 : block {
    a = dma.copy g => local;
    b = dma.copy g => local;
    c = dma.copy g => local;
    z = select(xx, a, b, c);
  }
}

// (No [assert-site] message for foo — assertions are already ENTRY.)

// -----------------------------------------------------------------------
// DEF_SITE with local alias: int zz = xx; select(zz, …).
// The factor `zz` is a local variable, so the assertion is classified as
// DEF_SITE.  The assertion expression references the underlying parameter
// symbol `xx`, so the AssertSite pass promotes it to ENTRY.
// -----------------------------------------------------------------------

__co__ void bar(int xx) {
  global s32[1,2] g;
  int zz = xx;
  parallel by 1 : block {
    a = dma.copy g => local;
    b = dma.copy g => local;
    c = dma.copy g => local;
    z = select(zz, a, b, c);
  }
}

// The assertion for zz's DEF_SITE is hoisted to just after the zz decl.
// CHECK: [assert-site] (hoisted) assertion "The select factor `zz`{{.*}}greater than or equal to 0" placed at {{.*}}.co:{{.*}} (after)
// CHECK: [assert-site] (hoisted) assertion "The select factor `zz`{{.*}}less than 3,{{.*}}" placed at {{.*}}.co:{{.*}} (after)
