#define BLOCK_M 64
#define BLOCK_N 64

// RUN: choreo -es -t cute -arch=sm_90a %s 2>&1 | FileCheck %s

// Test: 1D apply with IV in expression.
__co__ void test_frag_apply_1d() {
  parallel t by 128 : thread {
    frag f32[1024] buf {0.0f};
    apply {i} in buf.span {
      buf.at(i) = __to<f32>(i) * 2.0f;
    }
  }
}

// CHECK-LABEL: __choreo_device_test_frag_apply_1d
// CHECK: #pragma unroll
// CHECK: for (int __r = 0; __r < 8; ++__r)
// CHECK: buf[__r] = {{.*}}(__frag_iv_i) * 2.000000f
// CHECK: } // apply buf

// Test: 1D apply reading another fragment via .at().
__co__ void test_frag_apply_read_at() {
  parallel t by 128 : thread {
    frag f32[1024] a {0.0f};
    frag f32[1024] b {0.0f};
    apply {i} in a.span {
      a.at(i) = b.at(i) + 1.0f;
    }
  }
}

// CHECK-LABEL: __choreo_device_test_frag_apply_read_at
// CHECK: #pragma unroll
// CHECK: for (int __r = 0; __r < 8; ++__r)
// CHECK: a[__r] = b[__r] + 1.000000f
// CHECK: } // apply a

// Test: 2D apply with two IVs.
__co__ void test_frag_apply_2d() {
  parallel t by 128 : thread {
    frag f32[BLOCK_M, BLOCK_N] tile;
    apply {i, j} in tile.span {
      tile.at(i, j) = __to<f32>(i * BLOCK_N + j);
    }
  }
}

// CHECK-LABEL: __choreo_device_test_frag_apply_2d
// CHECK: #pragma unroll
// CHECK: for (int __r = 0; __r < 32; ++__r)
// CHECK: __frag_iv_i =
// CHECK: __frag_iv_j =
// CHECK: tile[__r] =
// CHECK: } // apply tile

// Test: apply equivalent of the softmax-like pattern.
__co__ void test_frag_apply_softmax() {
  parallel t by 128 : thread {
    frag f32[BLOCK_M, BLOCK_N] acc;
    frag f32[BLOCK_M] row_max;
    apply {i, j} in acc.span {
      acc.at(i, j) = acc.at(i, j) - row_max.at(i);
    }
  }
}

// CHECK-LABEL: __choreo_device_test_frag_apply_softmax
// CHECK: #pragma unroll
// CHECK: for (int __r = 0; __r < 32; ++__r)
// CHECK: acc[__r] = acc[__r] - row_max[
// CHECK: } // apply acc
