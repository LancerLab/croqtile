// RUN: choreo -es --runtime-check=all %s -o - | FileCheck %s --check-prefix=HIGH
// RUN: choreo -es --runtime-check=low %s -o - | FileCheck %s --check-prefix=LOW

__co__ void foo() {
    parallel p by 1 {
      shared s32 [4] buf;
      mutable int idx = call kernel();
      while (idx > 0) {
        x = buf.at(idx);
        idx = call kernel();
      }
    }
  }
}

// HIGH: int idx = kernel();
// HIGH: choreo::choreo_assert((static_cast<long long>(idx) < 4{{(LL)?}})

// LOW: int idx = kernel();
// LOW-NOT: choreo::choreo_assert((static_cast<long long>(idx) < 4{{(LL)?}})
