// REQUIRES: TARGET-CPU
// RUN: choreo -gs %target %s -o %s.cc.result && bash %s.cc.result --execute | FileCheck --match-full-lines %s && rm -f %s.cc.result

// --- Test 1: 2D parallel element-wise add ---
__co__ void ele_add_2d(s32 [8, 64] a, s32 [8, 64] b, s32 [8, 64] c) {
  parallel p by 8
    parallel q by 64
      c.at(p, q) = a.at(p, q) + b.at(p, q);
}

// --- Test 2: DMA load, compute in-place, DMA store ---
__co__ auto dma_add(s32 [64] a, s32 [64] b) {
  s32 [64] result;

  parallel by 1 {
    fa = dma.copy a => shared;
    fb = dma.copy b => shared;
    shared s32 [64] out;
    parallel p by 64
      out.at(p) = fa.data.at(p) + fb.data.at(p);
    dma.copy out => result;
  }

  return result;
}

int main() {
  {
    auto a = choreo::make_spandata<choreo::s32>(8, 64);
    auto b = choreo::make_spandata<choreo::s32>(8, 64);
    auto c = choreo::make_spandata<choreo::s32>(8, 64);
    for (size_t i = 0; i < 8; ++i)
      for (size_t j = 0; j < 64; ++j) {
        a[i][j] = i * 64 + j;
        b[i][j] = (i + 1) * (j + 1);
      }

    ele_add_2d(a.view(), b.view(), c.view());

    for (size_t i = 0; i < 8; ++i)
      for (size_t j = 0; j < 64; ++j)
        choreo::choreo_assert(a[i][j] + b[i][j] == c[i][j], "ele_add_2d mismatch");

    std::cout << "Test ele_add_2d Passed" << std::endl;
  }

  {
    auto a = choreo::make_spandata<choreo::s32>(64);
    auto b = choreo::make_spandata<choreo::s32>(64);
    for (size_t i = 0; i < 64; ++i) {
      a[i] = i * 5;
      b[i] = i * 3 + 2;
    }

    auto res = dma_add(a.view(), b.view());
    for (size_t i = 0; i < 64; ++i)
      choreo::choreo_assert(a[i] + b[i] == res[i], "dma_add mismatch");

    std::cout << "Test dma_add Passed" << std::endl;
  }
}

// CHECK: Test ele_add_2d Passed
// CHECK: Test dma_add Passed
